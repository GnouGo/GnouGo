# ── Build artifacts ──
**/bin/
**/obj/
**/out/

# ── Node modules (rebuilt in Docker) ──
**/node_modules/

# ── IDE / OS ──
**/.vs/
**/.vscode/
**/.idea/
**/.git/
**/.gitignore
**/Thumbs.db
**/.DS_Store
**/*.user
**/*.suo

# ── Docker ──
**/.dockerignore
**/docker-compose*.yml

# ── Test projects ──
tests/

# ── Temporary files ──
tmp_explore/

# ── Local data (recreated at runtime) ──
**/data/*.db
**/data/*.db-*

