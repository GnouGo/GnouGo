{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://localhost:5400",
  "LLM": {
    "DefaultProvider": "OpenAi",
    "DefaultModel": "gpt-4o-mini",
    "Models": {
      "OpenAi": {
        "Url": "https://api.openai.com/v1",
        "ApiKey": ""
      },
      "Ollama": {
        "Url": "http://localhost:11434",
        "Type": "ollama"
      },
      "Copilot": {
        "Url": "https://models.github.ai/inference",
        "Type": "copilot",
        "ApiKey": ""
      }
    },
    "McpServers": {
      "Github": {
        "Type": "http",
        "Description": "GitHub repository automation, file access, and developer workflows",
        "Url": "https://api.githubcopilot.com/mcp/",
        "ApiKey": ""
      },
      "GnOuGo.Browser.Mcp": {
        "Type": "stdio",
        "Description": "Web navigation via Playwright.NET MCP server",
        "Command": "dotnet",
        "Args": [
          "run",
          "--project",
          "../../GnOuGo.Browser.Mcp/GnOuGo.Browser.Mcp.csproj"
        ]
      },
      "GnOuGo.Cmd.Mcp": {
        "Type": "stdio",
        "Description": "Secure allowlisted command execution via stdio MCP server",
        "Command": "dotnet",
        "Args": [
          "run",
          "--project",
          "../../GnOuGo.Cmd.Mcp/GnOuGo.Cmd.Mcp.csproj"
        ]
      },
      "GnOuGo.Agent.Mcp": {
        "Type": "stdio",
        "Description": "User chat history store (append/get conversations) via MCP",
        "Command": "dotnet",
        "Args": [
          "run",
          "--project",
          "../../GnOuGo.Agent.Mcp/GnOuGo.Agent.Mcp.csproj"
        ]
      },
      "GnOuGo.KeyVault.Mcp": {
        "Type": "stdio",
        "Description": "Encrypted secret manager (write-only, no secret value exposure) via MCP",
        "Command": "dotnet",
        "Args": [
          "run",
          "--project",
          "../../GnOuGo.KeyVault.Mcp/GnOuGo.KeyVault.Mcp.csproj"
        ]
      }
    }
  },
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "GnOuGo.Flow.Server",
    "OtlpEndpoint": "http://localhost:4317",
    "Protocol": "Grpc",
    "TenantId": null
  }
}
