{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "LLM": {
    "DefaultProvider": "OpenAi",
    "DefaultModel": "gpt-4o-mini",
    "Models": {
      "OpenAi": {
        "Url": "https://api.openai.com/v1",
        "ApiKey": "",
        "Type": "openai"
      }
    },
    "McpServers": {
      "GnOuGo.Agent.Mcp": {
        "Type": "stdio",
        "Description": "Agent management (CRUD for agent definitions, schedules, and workflows)",
        "Command": "dotnet",
        "Args": [
          "run",
          "--project",
          "src/GnOuGo.Agent.Mcp/GnOuGo.Agent.Mcp.csproj"
        ]
      },
      "GnOuGo.KeyVault.Mcp": {
        "Type": "stdio",
        "Description": "Encrypted secret manager (write-only, no secret value exposure) via MCP",
        "Command": "dotnet",
        "Args": [
          "run",
          "--project",
          "src/GnOuGo.Agent.Mcp/GnOuGo.Agent.Mcp.csproj"
        ]
      }
    }
  },
  "KeyVault": {
    "DatabasePath": "data/gnougo-keyvault.db"
  },
  "OpenTelemetry": {
    "Enabled": false,
    "ServiceName": "GnOuGo.Agent.Server",
    "OtlpEndpoint": "http://localhost:4317",
    "Protocol": "Grpc",
    "TenantId": null,
    "IncludeAspNetCoreTraces": false
  },
  "ModelCatalogCache": {
    "Enabled": true,
    "AbsoluteExpirationSeconds": 30
  }
}
