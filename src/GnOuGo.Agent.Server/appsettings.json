{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "OtlpTenantCollector": "Warning",
      "Grpc.AspNetCore.Server": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Agent": {
    "DatabasePath": "data/gnougo-agent.db"
  },
  "LLM": {
    "DangerousAcceptAnyServerCertificate": false,
    "DefaultProvider": "OpenAi",
    "DefaultModel": "gpt-4o-mini",
    "Models": {
      "OpenAi": {
        "Url": "https://api.openai.com/v1",
        "ApiKey": "",
        "Type": "openai"
      }
    },
    "McpServers": {
      "GnOuGo.Browser.Mcp": {
        "Type": "stdio",
        "Description": "Web navigation via Playwright.NET MCP server",
        "DiscoveryTimeoutSeconds": 60,
        "Command": "tools/GnOuGo.Browser.Mcp/GnOuGo.Browser.Mcp",
        "Args": []
      },
      "GnOuGo.Cmd.Mcp": {
        "Type": "stdio",
        "Description": "Secure allowlisted command execution via stdio MCP server",
        "DiscoveryTimeoutSeconds": 30,
        "Command": "tools/GnOuGo.Cmd.Mcp/GnOuGo.Cmd.Mcp",
        "Args": []
      },
      "GnOuGo.Document.Mcp": {
        "Type": "stdio",
        "Description": "Document read/write MCP server (PDF, DOCX, XLSX, PPTX, TXT, MD, CSV, JSON, XML, YAML)",
        "DiscoveryTimeoutSeconds": 45,
        "Command": "tools/GnOuGo.Document.Mcp/GnOuGo.Document.Mcp",
        "Args": []
      },
      "GnOuGo.GithubCopilot.Mcp": {
        "Type": "stdio",
        "Description": "Code project operations via stdio MCP server, including safe file operations and GitHub Copilot suggestions",
        "DiscoveryTimeoutSeconds": 60,
        "CallTimeoutSeconds": 1200,
        "Command": "tools/GnOuGo.GithubCopilot.Mcp/GnOuGo.GithubCopilot.Mcp",
        "Args": []
      },
      "GnOuGo.Git.Mcp": {
        "Type": "stdio",
        "Description": "Git repository workflows via stdio MCP server using LibGit2Sharp",
        "DiscoveryTimeoutSeconds": 60,
        "CallTimeoutSeconds": 1200,
        "Command": "tools/GnOuGo.Git.Mcp/GnOuGo.Git.Mcp",
        "Args": []
      },
      "GnOuGo.Agent.Mcp": {
        "Type": "http",
        "Description": "Agent management and chat history exposed by the local Agent server via MCP HTTP",
        "Url": "http://127.0.0.1:0/mcp/agent"
      },
      "GnOuGo.KeyVault.Mcp": {
        "Type": "http",
        "Description": "Encrypted secret manager exposed by the local Agent server via MCP HTTP",
        "Url": "http://127.0.0.1:0/mcp/keyvault"
      },
      "GnOuGo.DocIngestor.Mcp": {
        "Type": "http",
        "Description": "Document ingestion and vector search exposed by the local Agent server via MCP HTTP",
        "Url": "http://127.0.0.1:0/mcp/docs-ingestor"
      }
    }
  },
  "KeyVault": {
    "DatabasePath": "data/gnougo-keyvault.db"
  },
  "DocsIngestorMcp": {
    "DatabasePath": "data/gnougo-docs-ingestor-mcp.db",
    "VectorDatabasePath": "data/gnougo-docs-ingestor-vectors.sqlite",
    "OriginalsDirectory": "data/docs-ingestor/originals"
  },
  "Database": {
    "Path": "data/gnougo-telemetry.db"
  },
  "DevMode": {
    "Enabled": true
  },
  "OtlpCollector": {
    "Enabled": true,
    "Host": "127.0.0.1",
    "GrpcPort": 4317,
    "HttpPort": 4318,
    "ExposeHealthEndpoint": true
  },
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "GnOuGo.Agent.Server",
    "OtlpEndpoint": "http://127.0.0.1:4317",
    "Protocol": "Grpc",
    "TenantId": null,
    "IncludeAspNetCoreTraces": true
  },
  "TraceDebug": {
    "Enabled": false,
    "BaseUrl": "http://127.0.0.1:4318",
    "ServiceName": "GnOuGo.Agent.Server",
    "RecentTraceLimit": 20,
    "RefreshIntervalSeconds": 2,
    "RequestTimeoutSeconds": 10
  },
  "ModelCatalogCache": {
    "Enabled": true,
    "AbsoluteExpirationSeconds": 30
  }
}
