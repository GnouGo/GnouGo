@namespace GnOuGo.Agent.Server.Components
@using Microsoft.AspNetCore.Hosting
@inject GnOuGo.Agent.Server.AppVersionInfo VersionInfo
@inject IWebHostEnvironment WebHostEnvironment

@{
    const string faviconPath = "favicon.svg";
    const string blazorWebScriptPath = "_framework/blazor.web.js";
    var appCssPath = VersionedAsset("ui/app.css");
    var appJsPath = VersionedAsset("ui/app.js");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />

    <title>GnOuGo.Agent</title>
    <meta name="description" content="GnOuGo.Agent — a lightweight chat UI with local history, Markdown rendering, and diagram support." />

    <link rel="icon" type="image/svg+xml" href="@faviconPath" />

    <!-- UI bundle generated by Vite (SCSS + offline JS libs). -->
    <link rel="stylesheet" href="@appCssPath" />

    <HeadOutlet />
</head>
<body>
    <Routes @rendermode="RenderMode.InteractiveServer" />

    <script>
        (function () {
            try {
                var current = new URL(window.location.href);
                var token = current.searchParams.get('desktopToken');
                if (!token) return;
                navigator.sendBeacon('/desktop/page-loaded/' + encodeURIComponent(token));
            } catch {
                // ignore
            }
        })();
    </script>

    <script src="@blazorWebScriptPath"></script>

    <!-- Offline UI helpers (Mermaid/C4/Markdown, etc.) built by Vite into wwwroot/ui. -->
    <script type="module" src="@appJsPath"></script>
</body>
</html>

@code {
    private string VersionedAsset(string relativePath)
    {
        var version = VersionInfo.Version;
        var webRoot = WebHostEnvironment.WebRootPath;
        if (!string.IsNullOrWhiteSpace(webRoot))
        {
            var localPath = relativePath.Replace('/', Path.DirectorySeparatorChar);
            var fullPath = Path.Combine(webRoot, localPath);
            if (File.Exists(fullPath))
                version = File.GetLastWriteTimeUtc(fullPath).Ticks.ToString();
        }

        return $"{relativePath}?v={Uri.EscapeDataString(version)}";
    }
}
