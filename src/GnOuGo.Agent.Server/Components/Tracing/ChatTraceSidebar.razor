@using GnOuGo.Agent.Server.Telemetry
@implements IAsyncDisposable
@inject TraceDebugService TraceDebug
@if (IsOpen)
{
    <button class="gnougo-trace-panel__backdrop" type="button" aria-label="Close trace panel" @onclick="HandleCloseAsync"></button>
}
<aside class="gnougo-trace-panel @(IsOpen ? "gnougo-trace-panel--open" : string.Empty)" aria-hidden="@(!IsOpen)">
    <header class="gnougo-trace-panel__header">
        <div>
            <div class="gnougo-trace-panel__eyebrow">OpenTelemetry / GenAI / RAG</div>
            <h2 class="gnougo-trace-panel__title">Message Trace Debug</h2>
            <div class="gnougo-trace-panel__meta">
                <span>Correlation: <code>@(Message?.CorrelationId ?? "n/a")</code></span>
                <span>Trace: <code>@(_snapshot.TraceId ?? Message?.TraceId ?? "pending")</code></span>
            </div>
        </div>
        <div class="gnougo-trace-panel__header-actions">
            <button class="gnougo-trace-panel__toggle"
                    type="button"
                    @onclick="ToggleRenderMode"
                    title="Toggle between formatted rendering and raw text">
                @(_renderFormatted ? "Formatted" : "Raw")
            </button>
            <span class="gnougo-trace-panel__badge @GetStatusBadgeClass()">@GetStatusLabel()</span>
            <button class="gnougo-trace-panel__close" type="button" @onclick="HandleCloseAsync" aria-label="Close trace panel">x</button>
        </div>
    </header>
    <nav class="gnougo-trace-panel__tabs" aria-label="Trace debug sections">
        <button class="gnougo-trace-panel__tab @GetTabClass(TracePanelTab.Traces)"
                type="button"
                role="tab"
                aria-selected="@(_activeTab == TracePanelTab.Traces)"
                @onclick="() => SelectTab(TracePanelTab.Traces)">
            <span>Traces</span>
            <span class="gnougo-trace-panel__tab-count">@(_snapshot.Trace?.Spans.Count ?? 0)</span>
        </button>
        <button class="gnougo-trace-panel__tab @GetTabClass(TracePanelTab.Logs)"
                type="button"
                role="tab"
                aria-selected="@(_activeTab == TracePanelTab.Logs)"
                @onclick="() => SelectTab(TracePanelTab.Logs)">
            <span>Logs</span>
            <span class="gnougo-trace-panel__tab-count">@_snapshot.Logs.Count</span>
        </button>
    </nav>
    <div class="gnougo-trace-panel__body">
        @if (!IsOpen || Message is null)
        {
            <div class="gnougo-trace-panel__state">
                <div class="gnougo-trace-panel__state-title">Select a GnOuGo message</div>
                <div class="gnougo-trace-panel__state-text">Open a message trace to inspect the full RAG execution in real time.</div>
            </div>
        }
        else if (!_snapshot.Availability.Enabled)
        {
            <div class="gnougo-trace-panel__state gnougo-trace-panel__state--warning">
                <div class="gnougo-trace-panel__state-title">Trace debugging unavailable</div>
                <div class="gnougo-trace-panel__state-text">@_snapshot.Availability.Message</div>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(_loadError))
        {
            <div class="gnougo-trace-panel__state gnougo-trace-panel__state--error">
                <div class="gnougo-trace-panel__state-title">Unable to load live telemetry</div>
                <div class="gnougo-trace-panel__state-text">@_loadError</div>
            </div>
        }
        else if (_activeTab == TracePanelTab.Logs)
        {
            <ChatTraceLogs @key="GetPanelContentKey()"
                           Logs="_snapshot.Logs"
                           IsLoading="_isLoading"
                           RenderFormatted="_renderFormatted" />
        }
        else if (_snapshot.Trace is null)
        {
            <div class="gnougo-trace-panel__state">
                <div class="gnougo-trace-panel__state-title">@(_snapshot.Pending ? "Waiting for spans..." : "Trace not found")</div>
                <div class="gnougo-trace-panel__state-text">@_snapshot.Message</div>
                @if (_isLoading)
                {
                    <div class="gnougo-trace-panel__spinner-row">
                        <span class="gnougo-trace-panel__spinner"></span>
                        <span>Polling the OTLP collector...</span>
                    </div>
                }
            </div>
        }
        else
        {
            <ChatTraceTraces @key="GetPanelContentKey()"
                             Trace="_snapshot.Trace"
                             CorrelationId="@Message.CorrelationId"
                             SnapshotMessage="@_snapshot.Message"
                             SelectedSpanId="@_selectedSpanId"
                             SelectedSpanIdChanged="@OnSelectedSpanChanged"
                             RenderFormatted="_renderFormatted" />
        }
    </div>
</aside>
@code {
    [Parameter] public ChatMessageDto? Message { get; set; }
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    private TraceDebugSnapshot _snapshot = new(
        new TraceDebugAvailability(false, "Trace debug not initialized yet."),
        CorrelationId: null,
        TraceId: null,
        Trace: null,
        Logs: [],
        Pending: false,
        Message: "Select a message to inspect.");
    private CancellationTokenSource? _refreshCts;
    private string? _parameterKey;
    private bool _isLoading;
    private string? _loadError;
    private string? _selectedSpanId;
    private bool _renderFormatted = true;
    private bool _stickySpanSelection = true;
    private TracePanelTab _activeTab = TracePanelTab.Traces;
    private bool _isDisposed;

    protected override async Task OnParametersSetAsync()
    {
        if (!IsOpen || Message is null)
        {
            StopRefreshLoop();
            _parameterKey = null;
            return;
        }
        var nextKey = string.Join('|', Message.MessageId ?? string.Empty, Message.CorrelationId ?? string.Empty, Message.TraceId ?? string.Empty, IsOpen);
        if (string.Equals(nextKey, _parameterKey, StringComparison.Ordinal))
            return;
        _parameterKey = nextKey;
        _selectedSpanId = null;
        _loadError = null;
        _activeTab = TracePanelTab.Traces;
        StopRefreshLoop();
        _refreshCts = new CancellationTokenSource();
        _isLoading = true;
        _ = RunRefreshLoopAsync(_refreshCts.Token);
        await Task.CompletedTask;
    }
    public ValueTask DisposeAsync()
    {
        _isDisposed = true;
        StopRefreshLoop();
        return ValueTask.CompletedTask;
    }

    private async Task RunRefreshLoopAsync(CancellationToken ct)
    {
        try
        {
            var correlationId = Message?.CorrelationId;
            var traceId = Message?.TraceId;
            await foreach (var snapshot in TraceDebug.StreamSnapshotsAsync(correlationId, traceId, ct))
            {
                if (!IsRefreshActive(ct))
                    break;

                await InvokeAsync(() =>
                {
                    if (!IsRefreshActive(ct))
                        return;

                    // Keep selected span detail stable while user is inspecting one span.
                    if (_stickySpanSelection
                        && _activeTab == TracePanelTab.Traces
                        && !string.IsNullOrWhiteSpace(_selectedSpanId))
                    {
                        return;
                    }

                    ApplySnapshot(snapshot);
                    _isLoading = false;
                    _loadError = null;
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException) when (ct.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            if (!IsRefreshActive(ct))
                return;

            await InvokeAsync(() =>
            {
                if (!IsRefreshActive(ct))
                    return;

                _loadError = ex.Message;
                _isLoading = false;
                StateHasChanged();
            });
        }
    }

    private void ApplySnapshot(TraceDebugSnapshot snapshot)
    {
        _snapshot = snapshot;
        if (_snapshot.Trace is not null && !string.IsNullOrWhiteSpace(_selectedSpanId))
        {
            var matchingSpan = _snapshot.Trace.Spans.FirstOrDefault(
                span => string.Equals(span.SpanId, _selectedSpanId, StringComparison.OrdinalIgnoreCase));

            // Keep selection stable across refreshes even if span id casing changes.
            _selectedSpanId = matchingSpan?.SpanId;
        }
    }
    private void StopRefreshLoop()
    {
        if (_refreshCts is null)
            return;
        try { _refreshCts.Cancel(); }
        catch (ObjectDisposedException) { }
        _refreshCts.Dispose();
        _refreshCts = null;
    }
    private Task HandleCloseAsync() => OnClose.InvokeAsync();
    private void ToggleRenderMode() => _renderFormatted = !_renderFormatted;
    private void SelectTab(TracePanelTab tab) => _activeTab = tab;

    private async Task OnSelectedSpanChanged(string? spanId)
    {
        _selectedSpanId = spanId;
        await InvokeAsync(StateHasChanged);
    }

    private string GetTabClass(TracePanelTab tab)
        => _activeTab == tab ? "gnougo-trace-panel__tab--active" : string.Empty;

    private string GetStatusBadgeClass()
    {
        if (!_snapshot.Availability.Enabled)
            return "gnougo-trace-panel__badge--disabled";
        if (!string.IsNullOrWhiteSpace(_loadError))
            return "gnougo-trace-panel__badge--error";
        if (_snapshot.Trace is not null)
            return "gnougo-trace-panel__badge--live";
        return "gnougo-trace-panel__badge--pending";
    }
    private string GetStatusLabel()
    {
        if (!_snapshot.Availability.Enabled)
            return "Disabled";
        if (!string.IsNullOrWhiteSpace(_loadError))
            return "Error";
        if (_snapshot.Trace is not null)
            return _isLoading ? "Live" : "Loaded";
        return _snapshot.Pending ? "Pending" : "Idle";
    }

    private bool IsRefreshActive(CancellationToken ct)
        => !_isDisposed
            && !ct.IsCancellationRequested
            && IsOpen
            && _refreshCts is not null
            && ct == _refreshCts.Token;

    private string GetPanelContentKey()
        => string.Join('|',
            _parameterKey ?? "no-message",
            _activeTab,
            _snapshot.TraceId ?? "no-trace",
            _selectedSpanId ?? "no-span");

    private enum TracePanelTab
    {
        Traces,
        Logs
    }
}
