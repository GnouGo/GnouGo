@using System.Globalization
@using GnOuGo.Agent.Server.Telemetry
@{
    var genAiAttributes = Span.Attributes
        .Where(pair => pair.Key.StartsWith("gen_ai.", StringComparison.OrdinalIgnoreCase) || pair.Key.StartsWith("llm.", StringComparison.OrdinalIgnoreCase))
        .ToDictionary(pair => pair.Key, pair => pair.Value, StringComparer.Ordinal);
    var otherAttributes = Span.Attributes
        .Where(pair => !pair.Key.StartsWith("gen_ai.", StringComparison.OrdinalIgnoreCase) && !pair.Key.StartsWith("llm.", StringComparison.OrdinalIgnoreCase))
        .ToDictionary(pair => pair.Key, pair => pair.Value, StringComparer.Ordinal);
}
<div class="gnougo-trace-detail">
    <div class="gnougo-trace-detail__header">
        <h3>@Span.Name</h3>
        <span>@TraceDebugUiHelpers.FormatDuration(TraceDebugUiHelpers.GetSpanDurationMs(Span))</span>
    </div>
    @if (!string.IsNullOrWhiteSpace(Span.StatusMessage))
    {
        <div class="gnougo-trace-detail__error">@Span.StatusMessage</div>
    }
    <div class="gnougo-trace-detail__section">
        <h4>Overview</h4>
        <table class="gnougo-trace-detail__table">
            <tbody>
                <tr><td>Span Id</td><td><code>@Span.SpanId</code></td></tr>
                <tr><td>Parent</td><td><code>@(Span.ParentSpanId ?? "root")</code></td></tr>
                <tr><td>Status</td><td>@TraceDebugUiHelpers.GetStatusLabel(Span.StatusCode)</td></tr>
                <tr><td>Kind</td><td>@TraceDebugUiHelpers.GetKindLabel(Span.Kind)</td></tr>
                <tr><td>Start</td><td>@Span.StartUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss.fff", CultureInfo.InvariantCulture)</td></tr>
                <tr><td>End</td><td>@Span.EndUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss.fff", CultureInfo.InvariantCulture)</td></tr>
            </tbody>
        </table>
    </div>
    <TraceAttributeTable Title="GenAI attributes" Attributes="genAiAttributes" RenderFormatted="RenderFormatted" />
    <TraceAttributeTable Title="Attributes" Attributes="otherAttributes" RenderFormatted="RenderFormatted" />
    <div class="gnougo-trace-detail__section">
        <h4>Events</h4>
        @if (Span.Events.Count == 0)
        {
            <div class="gnougo-trace-detail__empty">No events on this span.</div>
        }
        else
        {
            @foreach (var traceEvent in Span.Events)
            {
                <div class="gnougo-trace-detail__event">
                    <div class="gnougo-trace-detail__event-head">
                        <strong>@traceEvent.Name</strong>
                        <span>@traceEvent.TimeUtc.ToLocalTime().ToString("HH:mm:ss.fff", CultureInfo.InvariantCulture)</span>
                    </div>
                    <TraceAttributeTable Title="Event attributes" Attributes="traceEvent.Attributes" RenderFormatted="RenderFormatted" />
                </div>
            }
        }
    </div>
</div>
@code {
    [Parameter, EditorRequired] public TraceSpanDto Span { get; set; } = default!;
    [Parameter] public bool RenderFormatted { get; set; }
}
