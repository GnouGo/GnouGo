@using System.Globalization
@using GnOuGo.Agent.Server.Telemetry
<div class="gnougo-trace-summary__hero">
    <div class="gnougo-trace-summary__hero-title">Live logs for this answer</div>
    <div class="gnougo-trace-summary__hero-text">Logs are refreshed with the trace snapshot and filtered by the message trace/correlation metadata.</div>
    @if (IsLoading)
    {
        <div class="gnougo-trace-panel__spinner-row">
            <span class="gnougo-trace-panel__spinner"></span>
            <span>Refreshing correlated logs...</span>
        </div>
    }
</div>
@if (_logs.Count == 0)
{
    <div class="gnougo-trace-panel__state">
        <div class="gnougo-trace-panel__state-title">No logs yet</div>
        <div class="gnougo-trace-panel__state-text">Waiting for OpenTelemetry logs attached to this trace or correlation identifier.</div>
    </div>
}
else
{
    <div class="gnougo-trace-logs" aria-live="polite">
        @foreach (var log in _logs)
        {
            var logKey = log.Key;
            var logEntry = log.Log;
            var isOpen = _openLogKeys.Contains(logKey);
            <section class="gnougo-trace-log gnougo-trace-log--@TraceDebugUiHelpers.GetSeverityClass(logEntry)" @key="logKey">
                <button class="gnougo-trace-log__summary"
                        type="button"
                        aria-expanded="@isOpen"
                        @onclick="() => ToggleLog(logKey)">
                    <span class="gnougo-trace-log__chevron" aria-hidden="true">v</span>
                    <span class="gnougo-trace-log__time">@logEntry.ReceivedUtc.ToLocalTime().ToString("HH:mm:ss.fff", CultureInfo.InvariantCulture)</span>
                    <span class="gnougo-trace-log__severity">@TraceDebugUiHelpers.GetSeverityLabel(logEntry)</span>
                    <span class="gnougo-trace-log__service">@(logEntry.ServiceName ?? "service n/a")</span>
                    <span class="gnougo-trace-log__body">@(string.IsNullOrWhiteSpace(logEntry.Body) ? "(empty log body)" : logEntry.Body)</span>
                </button>
                @if (isOpen)
                {
                    <div class="gnougo-trace-log__content">
                        @if (!string.IsNullOrWhiteSpace(logEntry.Body))
                        {
                            <div class="gnougo-trace-detail__section">
                                <h4>Body</h4>
                                @TraceDebugValueRenderer.RenderValue(logEntry.Body, RenderFormatted)
                            </div>
                        }
                        <div class="gnougo-trace-detail__section">
                            <h4>Log identifiers</h4>
                            <table class="gnougo-trace-detail__table">
                                <tbody>
                                    <tr><td>Received</td><td>@logEntry.ReceivedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss.fff", CultureInfo.InvariantCulture)</td></tr>
                                    <tr><td>Severity</td><td>@TraceDebugUiHelpers.GetSeverityLabel(logEntry) (@logEntry.SeverityNumber)</td></tr>
                                    <tr><td>Service</td><td>@(logEntry.ServiceName ?? "n/a")</td></tr>
                                    <tr><td>Trace</td><td><code>@(logEntry.TraceId ?? "n/a")</code></td></tr>
                                    <tr><td>Span</td><td><code>@(logEntry.SpanId ?? "n/a")</code></td></tr>
                                </tbody>
                            </table>
                        </div>
                        <TraceAttributeTable Title="Attributes" Attributes="logEntry.Attributes" RenderFormatted="RenderFormatted" />
                        <TraceAttributeTable Title="Resource" Attributes="logEntry.Resource" RenderFormatted="RenderFormatted" />
                        <TraceAttributeTable Title="Scope" Attributes="logEntry.Scope" RenderFormatted="RenderFormatted" />
                    </div>
                }
            </section>
        }
    </div>
}
@code {
    [Parameter] public IReadOnlyList<TraceLogDto> Logs { get; set; } = [];
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public bool RenderFormatted { get; set; }
    private List<TraceLogItem> _logs = [];
    private readonly HashSet<string> _openLogKeys = new(StringComparer.Ordinal);

    protected override void OnParametersSet()
    {
        _logs = BuildLogItems(Logs);
        var currentKeys = _logs.Select(log => log.Key).ToHashSet(StringComparer.Ordinal);
        _openLogKeys.RemoveWhere(key => !currentKeys.Contains(key));
    }

    private void ToggleLog(string logKey)
    {
        if (!_openLogKeys.Add(logKey))
            _openLogKeys.Remove(logKey);
    }

    private static List<TraceLogItem> BuildLogItems(IReadOnlyList<TraceLogDto> logs)
    {
        var occurrenceCounts = new Dictionary<string, int>(StringComparer.Ordinal);
        var items = new List<TraceLogItem>(logs.Count);

        foreach (var log in logs.OrderByDescending(log => log.ReceivedUtc))
        {
            var baseKey = GetLogBaseKey(log);
            var occurrence = occurrenceCounts.GetValueOrDefault(baseKey);
            occurrenceCounts[baseKey] = occurrence + 1;
            var key = occurrence == 0 ? baseKey : string.Create(CultureInfo.InvariantCulture, $"{baseKey}|{occurrence}");
            items.Add(new TraceLogItem(log, key));
        }

        return items;
    }

    private static string GetLogBaseKey(TraceLogDto log)
    {
        if (log.Id is { } id && id != Guid.Empty)
            return string.Create(CultureInfo.InvariantCulture, $"id:{id:N}");

        return string.Join('|',
            "value",
            log.ReceivedUtc.UtcTicks.ToString(CultureInfo.InvariantCulture),
            log.TraceId ?? string.Empty,
            log.SpanId ?? string.Empty,
            log.SeverityNumber.ToString(CultureInfo.InvariantCulture),
            log.Body?.GetHashCode(StringComparison.Ordinal).ToString(CultureInfo.InvariantCulture) ?? string.Empty);
    }

    private sealed record TraceLogItem(TraceLogDto Log, string Key);
}
