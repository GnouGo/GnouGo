    /// <summary>
    /// Typewriter effect: appends text character by character with a small delay.
    /// </summary>
    private async Task TypewriterAppendAsync(string text, ChatMessageDto targetMsg, CancellationToken ct)
    {
        var pausePoints = CountTypewriterPausePoints(text);
        var pauseEvery = CalculateTypewriterPauseInterval(pausePoints);
        var seenPausePoints = 0;

        foreach (var ch in text)
        {
            ct.ThrowIfCancellationRequested();

            targetMsg = targetMsg with { Content = targetMsg.Content + ch };
            ReplaceLastAssistant(targetMsg);
            TouchActive();
            StateHasChanged();

            // Only delay every few characters for performance
            if (ch is ' ' or '\n' or '.' or ',' or '!' or '?')
            {
                seenPausePoints++;
                if (seenPausePoints % pauseEvery == 0)
                {
                    await Task.Delay(TypewriterDelayMs, ct);
                    await ScrollToBottomAsync();
                }
            }
        }

        await ScrollToBottomAsync();
    }

    private static int CountTypewriterPausePoints(string text)
        => text.Count(static ch => ch is ' ' or '\n' or '.' or ',' or '!' or '?');

    private static int CalculateTypewriterPauseInterval(int pausePoints)
    {
        if (pausePoints <= 0)
            return 1;

        var naturalDurationMs = pausePoints * TypewriterDelayMs;
        if (naturalDurationMs <= TypewriterMaxTotalDelayMs)
            return 1;

        return (int)Math.Ceiling(naturalDurationMs / (double)TypewriterMaxTotalDelayMs);
    }

    private async Task<bool> TryInitializeChatStateAsync()
    {
        try
        {
            await MergeServerConversationsAsync();
            EnsureActiveSession();
            if (_active is { Messages.Count: 0 })
                await TryHydrateSessionMessagesAsync(_active);
            SyncSessionsToDefaultAgent();
            _chatStatePending = false;
            return true;
        }
        catch (JSDisconnectedException)
        {
            return false;
        }
        catch (InvalidOperationException ex) when (IsDeferredJavaScriptInterop(ex))
        {
            return false;
        }
    }

    private static bool IsDeferredJavaScriptInterop(InvalidOperationException ex)
        => ex.Message.Contains("prerender", StringComparison.OrdinalIgnoreCase)
           || ex.Message.Contains("statically rendered", StringComparison.OrdinalIgnoreCase)
           || ex.Message.Contains("JavaScript interop", StringComparison.OrdinalIgnoreCase);

