@page "/"
@using System.Diagnostics
@using System.Text.Json
@using System.Text.Json.Nodes
@using System.Threading
@using Markdig
@using Microsoft.JSInterop
@using GnOuGo.Agent.Server.Components.Tracing

@inject IJSRuntime Js
@inject SmartFlowService SmartFlow
@inject AgentHumanInputProvider HumanInputProvider
@inject AgentUserConfigMcpClient UserConfigClient

<div class="sa-app">
    <aside class="sa-app__sidebar sa-sidebar @( _sidebarOpen ? "sa-sidebar--open" : "")">
        <div class="sa-sidebar__header">
            <div class="sa-sidebar__brand">
                <img class="sa-sidebar__logo" src="assets/gnougo-agent-logo.png" alt="GnOuGo.Agent" />
                <div class="sa-sidebar__brand-text">
                    <div class="sa-sidebar__title">GnOuGo.Agent</div>
                    <div class="sa-sidebar__subtitle">Chats stored locally</div>
                </div>
            </div>

            <button class="sa-sidebar__new" @onclick="NewChatAsync" type="button" title="New chat">
                <span class="sa-sidebar__new-icon">＋</span>
                <span class="sa-sidebar__new-text">New chat</span>
            </button>

            <button class="sa-sidebar__close" @onclick="ToggleSidebar" type="button" title="Close">
                ✕
            </button>
        </div>

        <nav class="sa-sidebar__list" aria-label="Chats">
            @if (_store.Sessions.Count == 0)
            {
                <div class="sa-sidebar__empty">No chats yet.</div>
            }
            else
            {
                @foreach (var s in _store.Sessions.OrderByDescending(x => x.UpdatedAtUnixMs))
                {
                    var isActive = string.Equals(_store.ActiveId, s.Id, StringComparison.Ordinal);
                    <button class="sa-sidebar__item @(isActive ? "sa-sidebar__item--active" : "")"
                            @onclick="@(() => SelectChatAsync(s.Id))"
                            type="button">
                        <div class="sa-sidebar__item-title">@s.Title</div>
                        <div class="sa-sidebar__item-meta">@FormatUpdatedAt(s.UpdatedAtUnixMs)</div>
                    </button>
                }
            }
        </nav>

        <div class="sa-sidebar__footer">
            <div class="sa-sidebar__hint">
                Tip: your history is stored in <span class="sa-sidebar__hint-strong">localStorage</span>.
            </div>
        </div>
    </aside>

    <main class="sa-app__main sa-chat">
        <header class="sa-chat__topbar">
            <button class="sa-chat__menu" @onclick="ToggleSidebar" type="button" title="Menu">
                ☰
            </button>

            <div class="sa-chat__topbar-title">
                @if (!string.IsNullOrWhiteSpace(_defaultAgentName))
                {
                    <span class="sa-chat__agent-badge" title="Active agent">🤖 @_defaultAgentName</span>
                    <span style="margin: 0 8px; opacity: 0.4;">|</span>
                }
                @(_active?.Title ?? "Chat")
            </div>

            <div class="sa-chat__topbar-actions">
                @if (_isStreaming)
                {
                    <div class="sa-chat__streaming" title="Streaming…">
                        <span class="sa-chat__streaming-dot"></span>
                        Streaming…
                    </div>
                }
            </div>
        </header>

        <section class="sa-chat__messages" id="chatMessages">
            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="sa-chat__error">@_error</div>
            }

            @if (_active is null || _active.Messages.Count == 0)
            {
                <div class="sa-chat__empty">
                    <div class="sa-chat__empty-title">Start a new chat</div>
                    <div class="sa-chat__empty-subtitle">Your messages and history stay in your browser.</div>
                </div>
            }
            else
            {
                @foreach (var msg in _active.Messages)
                {
                    var isUser = string.Equals(msg.Role, "user", StringComparison.OrdinalIgnoreCase);
                    var isThinking = string.Equals(msg.Role, "thinking", StringComparison.OrdinalIgnoreCase);
                    var isThought = string.Equals(msg.Role, "thought", StringComparison.OrdinalIgnoreCase);

                    @if (isThinking || isThought)
                    {
                        <article class="sa-chat__message @(isThought ? "sa-chat__message--thought" : "sa-chat__message--thinking")">
                            <div class="sa-chat__thinking">
                                <span class="sa-chat__thinking-icon">💭</span>
                                <span class="sa-chat__thinking-text">@msg.Content</span>
                            </div>
                        </article>
                    }
                    else
                    {
                        <article class="sa-chat__message @(isUser ? "sa-chat__message--user" : "sa-chat__message--assistant")">
                            <div class="sa-chat__bubble">
                                <div class="sa-chat__bubble-meta">
                                    <span class="sa-chat__bubble-role">@((isUser ? "You" : "GnOuGo.Agent"))</span>
                                    @if (!isUser)
                                    {
                                        var isTraceSelected = ReferenceEquals(_selectedTraceMessage, msg)
                                                              || (!string.IsNullOrWhiteSpace(_selectedTraceMessage?.MessageId)
                                                                  && string.Equals(_selectedTraceMessage?.MessageId, msg.MessageId, StringComparison.Ordinal));
                                        <button class="sa-chat__bubble-action @(isTraceSelected && _traceSidebarOpen ? "sa-chat__bubble-action--active" : "")"
                                                type="button"
                                                title="Open trace debug sidebar"
                                                @onclick="() => OpenTraceSidebar(msg)">
                                            🔎 Trace
                                        </button>
                                    }
                                </div>

                                <div class="sa-chat__bubble-text markdown-body">
                                    @RenderMarkdown(msg.Content)
                                </div>
                            </div>
                        </article>
                    }
                }
            }

            @if (_pendingHumanInput is not null)
            {
                <article class="sa-chat__message sa-chat__message--assistant">
                    <div class="sa-chat__bubble">
                        <div class="sa-chat__bubble-meta">
                            <span class="sa-chat__bubble-role">⚙️ Configuration</span>
                        </div>
                        <div class="sa-chat__bubble-text">
                            <p><strong>@_pendingHumanInput.Prompt</strong></p>

                            @if (!string.IsNullOrWhiteSpace(_pendingHumanInput.Context))
                            {
                                <div class="sa-chat__thinking">
                                    <span class="sa-chat__thinking-text" style="font-size: 0.85em; opacity: 0.8;">@_pendingHumanInput.Context</span>
                                </div>
                            }

                            @if (_pendingHumanInput.Choices is { Count: > 0 })
                            {
                                <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-top: 8px;">
                                    @foreach (var choice in _pendingHumanInput.Choices)
                                    {
                                        var c = choice;
                                        <button class="sa-composer__send"
                                                type="button"
                                                style="min-width: 80px;"
                                                @onclick="@(() => SubmitHumanInputChoice(c))">
                                            @c
                                        </button>
                                    }
                                </div>
                            }
                            else if (_pendingHumanInput.Fields is { Count: > 0 })
                            {
                                <div style="margin-top: 8px;">
                                    @foreach (var field in _pendingHumanInput.Fields)
                                    {
                                        <div style="margin-bottom: 8px;">
                                            <label style="display: block; font-weight: 600; margin-bottom: 2px;">
                                                @field.Name
                                                @if (field.Required) { <span style="color: #e74c3c;">*</span> }
                                            </label>
                                            @if (!string.IsNullOrWhiteSpace(field.Description))
                                            {
                                                <div style="font-size: 0.8em; opacity: 0.7; margin-bottom: 2px;">@field.Description</div>
                                            }
                                            @if (string.Equals(field.Type, "select", StringComparison.OrdinalIgnoreCase) && field.Options is { Count: > 0 })
                                            {
                                                <select class="sa-composer__input"
                                                        style="width: 100%; padding: 6px 10px; border-radius: 6px;"
                                                        value="@GetFieldValue(field.Name)"
                                                        @onchange="@(e => SetFieldValue(field.Name, e.Value?.ToString() ?? ""))">
                                                    @foreach (var option in field.Options)
                                                    {
                                                        <option value="@option">@option</option>
                                                    }
                                                </select>
                                            }
                                            else
                                            {
                                                <input type="text"
                                                       class="sa-composer__input"
                                                       style="width: 100%; padding: 6px 10px; border-radius: 6px;"
                                                       value="@GetFieldValue(field.Name)"
                                                       @onchange="@(e => SetFieldValue(field.Name, e.Value?.ToString() ?? ""))" />
                                            }
                                        </div>
                                    }
                                    <button class="sa-composer__send"
                                            type="button"
                                            style="margin-top: 8px;"
                                            @onclick="SubmitHumanInputFields">
                                        Submit
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </article>
            }
        </section>

        <footer class="sa-chat__composer">
            <EditForm class="sa-composer" Model="_model" OnValidSubmit="SendAsync">
                <DataAnnotationsValidator />
                <div class="sa-composer__row">
                    <textarea class="sa-composer__input"
                              @bind="_model.Prompt"
                              @bind:event="oninput"
                              placeholder="Write a message or YAML… (/llm, /mcp, /agent, Markdown, YAML supported)"

                              rows="1"
                              disabled="@_isStreaming"
                              @onkeydown="OnKeyDown">
                    </textarea>

                    @if (_isStreaming)
                    {
                        <button class="sa-composer__send sa-composer__send--stop" type="button" @onclick="Stop" title="Stop">
                            <span class="sa-composer__send-text">Stop</span>
                        </button>
                    }
                    else
                    {
                        <button class="sa-composer__send" type="submit" disabled="@string.IsNullOrWhiteSpace(_model.Prompt)">
                            <span class="sa-composer__send-text">Send</span>
                        </button>
                    }
                </div>

                <div class="sa-composer__hint">
                    Enter to send • Shift+Enter for newline
                </div>
            </EditForm>
        </footer>
    </main>

    <ChatTraceSidebar Message="_selectedTraceMessage"
                      IsOpen="_traceSidebarOpen"
                      OnClose="CloseTraceSidebarAsync" />
</div>

@code
{
    private sealed class ComposeModel
    {
        public string Prompt { get; set; } = "";
    }

    private sealed class HumanInputModel
    {
        public string RunId { get; set; } = "";
        public string StepId { get; set; } = "";
        public string Prompt { get; set; } = "";
        public string? Context { get; set; }
        public List<string>? Choices { get; set; }
        public List<HumanInputFieldModel>? Fields { get; set; }
    }

    private sealed class HumanInputFieldModel
    {
        public string Name { get; set; } = "";
        public string Type { get; set; } = "string";
        public bool Required { get; set; }
        public string? Description { get; set; }
        public List<string>? Options { get; set; }
        public string? Default { get; set; }
    }

    private const string StorageKeyV2 = "gnougo-agent.sa-chat.store.v2";
    private const string LegacyStorageKey = "gnougo-sa-chat.sa-chat.history.v1";

    private static readonly MarkdownPipeline MdPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .DisableHtml()
        .Build();

    private readonly ComposeModel _model = new();
    private ChatStoreDto _store = new("", new List<ChatSessionDto>());
    private ChatSessionDto? _active;
    private string? _defaultAgentName;

    private bool _sidebarOpen;
    private bool _isStreaming;
    private string _error = "";
    private bool _browserStatePending = true;

    private CancellationTokenSource? _cts;
    private bool _needsMarkdownEnhance;

    private HumanInputModel? _pendingHumanInput;
    private readonly Dictionary<string, string> _fieldValues = new();
    private bool _traceSidebarOpen;
    private ChatMessageDto? _selectedTraceMessage;

    /// <summary>Accumulates all HITL prompt+response pairs so they can be grouped
    /// into a single message at the end of the flow.</summary>
    private readonly List<(string Question, string Answer)> _hitlLog = new();

    /// <summary>Typewriter delay in ms between characters.</summary>
    private const int TypewriterDelayMs = 12;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var snapshot = await UserConfigClient.GetAsync();
            _defaultAgentName = snapshot.DefaultAgent;
            EnsureActiveSession();
        }

        if (_browserStatePending)
        {
            var initialized = await TryInitializeBrowserStateAsync();
            if (initialized)
            {
                _needsMarkdownEnhance = true;
                StateHasChanged();
                await ScrollToBottomAsync();
                return;
            }
        }

        if (_needsMarkdownEnhance && !_isStreaming)
        {
            _needsMarkdownEnhance = false;
            try
            {
                await Js.InvokeVoidAsync("GnOuGo.Agent.markdown.enhance", "chatMessages");
            }
            catch (JSDisconnectedException)
            {
            }
            catch (InvalidOperationException ex) when (IsDeferredJavaScriptInterop(ex))
            {
            }
        }
    }

    private MarkupString RenderMarkdown(string markdown)
    {
        var html = Markdown.ToHtml(NormalizeMarkdown(markdown), MdPipeline);
        return (MarkupString)html;
    }

    private static string NormalizeMarkdown(string? markdown)
    {
        if (string.IsNullOrWhiteSpace(markdown))
            return markdown ?? "";

        var normalized = markdown.Replace("\r\n", "\n", StringComparison.Ordinal)
            .Replace('\r', '\n');

        var lines = normalized.Split('\n');
        var output = new List<string>(lines.Length + 8);

        for (var i = 0; i < lines.Length; i++)
        {
            var line = lines[i];
            var trimmed = line.Trim();
            var previousTrimmed = output.Count == 0 ? "" : output[^1].Trim();
            var nextTrimmed = i + 1 < lines.Length ? lines[i + 1].Trim() : "";

            if (!string.IsNullOrWhiteSpace(previousTrimmed)
                && (LooksLikeAtxHeading(trimmed) || LooksLikeTableHeader(trimmed, nextTrimmed)))
            {
                output.Add("");
            }

            output.Add(line);
        }

        return string.Join("\n", output);
    }

    private static bool LooksLikeAtxHeading(string line)
    {
        if (string.IsNullOrWhiteSpace(line) || !line.StartsWith('#'))
            return false;

        var index = 0;
        while (index < line.Length && line[index] == '#')
            index++;

        return index is > 0 and <= 6
            && index < line.Length
            && char.IsWhiteSpace(line[index]);
    }

    private static bool LooksLikeTableHeader(string line, string nextLine)
        => line.Contains('|', StringComparison.Ordinal)
           && LooksLikeTableSeparator(nextLine);

    private static bool LooksLikeTableSeparator(string line)
    {
        if (string.IsNullOrWhiteSpace(line) || !line.Contains('-', StringComparison.Ordinal))
            return false;

        var cells = line.Trim().Trim('|').Split('|', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
        if (cells.Length == 0)
            return false;

        foreach (var cell in cells)
        {
            var content = cell.Trim().Trim(':').Replace(" ", "", StringComparison.Ordinal);
            if (content.Length < 3 || content.Any(ch => ch != '-'))
                return false;
        }

        return true;
    }

    private void ToggleSidebar() => _sidebarOpen = !_sidebarOpen;
    private void CloseSidebar() => _sidebarOpen = false;

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (_isStreaming) return;
        if (e.Key is "Enter" && !e.ShiftKey)
        {
            if (!string.IsNullOrWhiteSpace(_model.Prompt))
                await SendAsync();
        }
    }

    /// <summary>
    /// Typewriter effect: appends text character by character with a small delay.
    /// </summary>
    private async Task TypewriterAppendAsync(string text, ChatMessageDto targetMsg, CancellationToken ct)
    {
        foreach (var ch in text)
        {
            ct.ThrowIfCancellationRequested();

            targetMsg = targetMsg with { Content = targetMsg.Content + ch };
            ReplaceLastAssistant(targetMsg);
            TouchActive();
            StateHasChanged();

            // Only delay every few characters for performance
            if (ch is ' ' or '\n' or '.' or ',' or '!' or '?')
            {
                await Task.Delay(TypewriterDelayMs, ct);
                await ScrollToBottomAsync();
            }
        }
    }

    private async Task<bool> TryInitializeBrowserStateAsync()
    {
        try
        {
            await LoadStoreAsync();
            var sessionsChanged = SyncSessionsToDefaultAgent();
            EnsureActiveSession();
            if (sessionsChanged)
                await PersistAsync();
            _browserStatePending = false;
            return true;
        }
        catch (JSDisconnectedException)
        {
            return false;
        }
        catch (InvalidOperationException ex) when (IsDeferredJavaScriptInterop(ex))
        {
            return false;
        }
    }

    private static bool IsDeferredJavaScriptInterop(InvalidOperationException ex)
        => ex.Message.Contains("prerender", StringComparison.OrdinalIgnoreCase)
           || ex.Message.Contains("statically rendered", StringComparison.OrdinalIgnoreCase)
           || ex.Message.Contains("JavaScript interop", StringComparison.OrdinalIgnoreCase);

    private async Task<ChatMessageDto> AppendAssistantContentAsync(
        ChatMessageDto assistantMsg,
        string? incomingText,
        CancellationToken ct)
    {
        if (_active is null)
            return assistantMsg;

        var text = incomingText ?? "";
        if (string.IsNullOrWhiteSpace(text))
            return assistantMsg;

        var current = assistantMsg.Content;
        if (string.Equals(current, text, StringComparison.Ordinal))
            return assistantMsg;

        if (!string.IsNullOrEmpty(current) && text.StartsWith(current, StringComparison.Ordinal))
        {
            var delta = text[current.Length..];
            if (!string.IsNullOrEmpty(delta))
                await TypewriterAppendAsync(delta, assistantMsg, ct);
        }
        else if (!string.IsNullOrEmpty(current) && current.StartsWith(text, StringComparison.Ordinal))
        {
            return assistantMsg;
        }
        else
        {
            var separator = NeedsResponseSeparator(current, text) ? "\n\n" : "";
            await TypewriterAppendAsync(separator + text, assistantMsg, ct);
        }

        return _active.Messages.LastOrDefault(m =>
                   string.Equals(m.Role, "assistant", StringComparison.OrdinalIgnoreCase))
               ?? assistantMsg;
    }

    private static bool NeedsResponseSeparator(string current, string next)
    {
        if (string.IsNullOrWhiteSpace(current) || string.IsNullOrWhiteSpace(next))
            return false;

        return !char.IsWhiteSpace(current[^1])
            && !char.IsWhiteSpace(next[0]);
    }

    private async Task SendAsync()
    {
        if (_active is null) return;
        if (_isStreaming) return;

        _error = "";
        var prompt = _model.Prompt.Trim();
        if (string.IsNullOrWhiteSpace(prompt))
            return;

        _model.Prompt = "";
        var correlationId = ActivityTraceId.CreateRandom().ToHexString();

        // Add user message
        var userMsg = new ChatMessageDto("user", prompt, MessageId: Guid.NewGuid().ToString("N"), CorrelationId: correlationId);
        _active.Messages.Add(userMsg);

        // Placeholder assistant message
        var assistantMsg = new ChatMessageDto("assistant", "", MessageId: Guid.NewGuid().ToString("N"), CorrelationId: correlationId);
        _active.Messages.Add(assistantMsg);

        TouchActive();
        await PersistAsync();

        _isStreaming = true;
        _cts = new CancellationTokenSource();

        StateHasChanged();
        await ScrollToBottomAsync();

        try
        {
            await foreach (var evt in SmartFlow.ExecuteAsync(prompt, correlationId, agentName: null, _cts.Token))
            {
                if (evt.Type is "trace.started")
                {
                    assistantMsg = assistantMsg with
                    {
                        CorrelationId = evt.CorrelationId ?? assistantMsg.CorrelationId,
                        TraceId = evt.TraceId
                    };
                    ReplaceLastAssistant(assistantMsg);
                    TouchActive();
                    StateHasChanged();
                    continue;
                }

                if (evt.Type.StartsWith("thinking:", StringComparison.Ordinal))
                {
                    var level = evt.Type.AsSpan(9).ToString(); // after "thinking:"

                    if (string.Equals(level, "response", StringComparison.OrdinalIgnoreCase))
                    {
                        // "response" level = final user-facing content (e.g. from configure-providers)
                        assistantMsg = await AppendAssistantContentAsync(assistantMsg, evt.Text, _cts.Token);
                    }
                    else
                    {
                        if (_active is null)
                            continue;

                        // Insert a thinking message before the assistant placeholder
                        var thinkingMsg = new ChatMessageDto("thinking", evt.Text ?? "");
                        var lastIdx = _active.Messages.Count - 1;
                        _active.Messages.Insert(lastIdx, thinkingMsg);
                        StateHasChanged();
                        await ScrollToBottomAsync();
                    }
                }
                else if (evt.Type is "answer" or "response")
                {
                    // Typewriter effect for the final answer
                    assistantMsg = await AppendAssistantContentAsync(assistantMsg, evt.Text, _cts.Token);
                }
                else if (evt.Type is "llm.chunk")
                {
                    // Intermediate LLM chunks — also typewriter
                    // (These are intermediate steps, not the final answer,
                    //  but we can show them to give feedback.)
                }
                else if (evt.Type is "error")
                {
                    // Detect HITL timeout and show a friendly message
                    var errText = evt.Text ?? "Unknown error";
                    if (errText.Contains("timed out", StringComparison.OrdinalIgnoreCase)
                        && errText.Contains("human", StringComparison.OrdinalIgnoreCase)
                        && _active is not null)
                    {
                        var timeoutMsg = new ChatMessageDto("assistant",
                            "⏱️ **Human input timed out.** The workflow was waiting for your response, "
                            + "but no input was received within the allowed time. "
                            + "Please try again — the workflow will re-prompt you for the required information.",
                            assistantMsg.MessageId,
                            assistantMsg.CorrelationId,
                            assistantMsg.TraceId);

                        // Replace the empty assistant placeholder (if any) instead of inserting alongside it
                        var replaced = false;
                        for (var i = _active.Messages.Count - 1; i >= 0; i--)
                        {
                            if (string.Equals(_active.Messages[i].Role, "assistant", StringComparison.OrdinalIgnoreCase)
                                && string.IsNullOrWhiteSpace(_active.Messages[i].Content))
                            {
                                _active.Messages[i] = timeoutMsg;
                                if (_selectedTraceMessage is not null
                                    && !string.IsNullOrWhiteSpace(_selectedTraceMessage.MessageId)
                                    && string.Equals(_selectedTraceMessage.MessageId, timeoutMsg.MessageId, StringComparison.Ordinal))
                                {
                                    _selectedTraceMessage = timeoutMsg;
                                }
                                replaced = true;
                                break;
                            }
                        }
                        if (!replaced)
                        {
                            _active.Messages.Add(timeoutMsg);
                            if (_selectedTraceMessage is not null
                                && !string.IsNullOrWhiteSpace(_selectedTraceMessage.MessageId)
                                && string.Equals(_selectedTraceMessage.MessageId, timeoutMsg.MessageId, StringComparison.Ordinal))
                            {
                                _selectedTraceMessage = timeoutMsg;
                            }
                        }

                        _pendingHumanInput = null;
                        _fieldValues.Clear();
                        StateHasChanged();
                        await ScrollToBottomAsync();
                    }
                    else
                    {
                        _error = errText;
                    }
                }
                else if (evt.Type is "agent_selected")
                {
                    if (!string.IsNullOrWhiteSpace(evt.Text))
                    {
                        _defaultAgentName = evt.Text;
                        SyncSessionsToDefaultAgent();
                        StateHasChanged();
                    }
                }
                else if (evt.Type == "human_input_request")
                {
                    // Parse the human input request and show it in the UI
                    var requestJson = JsonNode.Parse(evt.Text ?? "{}")?.AsObject();
                    if (requestJson is not null)
                    {
                        var model = new HumanInputModel
                        {
                            RunId = requestJson["run_id"]?.GetValue<string>() ?? "",
                            StepId = requestJson["step_id"]?.GetValue<string>() ?? "",
                            Prompt = requestJson["prompt"]?.GetValue<string>() ?? "",
                            Context = requestJson["context"]?.GetValue<string>(),
                        };

                        if (requestJson["choices"] is JsonArray choicesArr)
                            model.Choices = choicesArr.Select(c => c?.GetValue<string>() ?? "").ToList();

                        if (requestJson["fields"] is JsonArray fieldsArr)
                        {
                            model.Fields = new List<HumanInputFieldModel>();
                            foreach (var fNode in fieldsArr)
                            {
                                if (fNode is not JsonObject fObj) continue;
                                var field = new HumanInputFieldModel
                                {
                                    Name = fObj["name"]?.GetValue<string>() ?? "",
                                    Type = fObj["type"]?.GetValue<string>() ?? "string",
                                    Required = fObj["required"]?.GetValue<bool>() ?? false,
                                    Description = fObj["description"]?.GetValue<string>(),
                                    Options = fObj["options"] is JsonArray optionsArr
                                        ? optionsArr.Select(o => o?.GetValue<string>() ?? "").Where(o => !string.IsNullOrWhiteSpace(o)).ToList()
                                        : null,
                                    Default = fObj["default"]?.GetValue<string>(),
                                };
                                model.Fields.Add(field);
                            }
                        }

                        // Pre-populate field defaults
                        _fieldValues.Clear();
                        if (model.Fields is not null)
                        {
                            foreach (var f in model.Fields)
                            {
                                if (!string.IsNullOrEmpty(f.Default))
                                    _fieldValues[f.Name] = f.Default;
                            }
                        }

                        _pendingHumanInput = model;
                        StateHasChanged();
                        await ScrollToBottomAsync();
                    }
                }
            }

            // ── Group HITL interactions into a single user message ──
            if (_hitlLog.Count > 0 && _active is not null)
            {
                var sb = new System.Text.StringBuilder();
                sb.AppendLine("⚙️ **Configuration**\n");
                sb.AppendLine("| Step | Your choice |");
                sb.AppendLine("|------|-------------|");
                foreach (var (q, a) in _hitlLog)
                {
                    // Trim the prompt to keep the table compact
                    var shortQ = q.Length > 60 ? q[..57] + "…" : q;
                    sb.AppendLine($"| {shortQ} | `{a}` |");
                }

                var lastIdx = _active.Messages.Count - 1;
                _active.Messages.Insert(lastIdx,
                    new ChatMessageDto("user", sb.ToString()));
            }

            // Convert live thinking messages to "thought" (static, no pulse animation)
            if (_active is not null)
            {
                for (var i = 0; i < _active.Messages.Count; i++)
                {
                    if (string.Equals(_active.Messages[i].Role, "thinking", StringComparison.OrdinalIgnoreCase))
                        _active.Messages[i] = _active.Messages[i] with { Role = "thought" };
                }
            }

            // Update title if still default
            if (_active is not null &&
                (string.Equals(_active.Title, "New chat", StringComparison.OrdinalIgnoreCase) ||
                 string.Equals(_active.Title, "Migrated sa-chat", StringComparison.OrdinalIgnoreCase)))
            {
                try
                {
                    var title = await SmartFlow.SuggestTitleAsync(_active.Messages, _cts.Token);
                    if (!string.IsNullOrWhiteSpace(title))
                    {
                        _active = _active with { Title = title.Trim() };
                        ReplaceSession(_active);
                    }
                }
                catch (OperationCanceledException)
                {
                }
                catch (Exception)
                {
                    // Ignore title generation failures.
                }
            }
        }
        catch (OperationCanceledException)
        {
            // user hit Stop
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isStreaming = false;
            _pendingHumanInput = null;
            _fieldValues.Clear();
            _hitlLog.Clear();
            _cts?.Dispose();
            _cts = null;

            TouchActive();
            await PersistAsync();

            _needsMarkdownEnhance = true;
            StateHasChanged();
        }
    }

    private void Stop()
    {
        _cts?.Cancel();
    }

    private void SubmitHumanInputChoice(string choice)
    {
        if (_pendingHumanInput is null) return;

        var response = new JsonObject { ["response"] = choice };
        HumanInputProvider.TrySubmitResponse(_pendingHumanInput.RunId, _pendingHumanInput.StepId, response);

        // Log the interaction for the grouped summary (instead of inserting a message)
        _hitlLog.Add((_pendingHumanInput.Prompt, choice));

        _pendingHumanInput = null;
        _fieldValues.Clear();
        StateHasChanged();
    }

    private void SubmitHumanInputFields()
    {
        if (_pendingHumanInput is null) return;

        var response = new JsonObject();
        if (_pendingHumanInput.Fields is not null)
        {
            foreach (var field in _pendingHumanInput.Fields)
            {
                var value = _fieldValues.TryGetValue(field.Name, out var v) ? v : "";
                response[field.Name] = value;
            }
        }

        HumanInputProvider.TrySubmitResponse(_pendingHumanInput.RunId, _pendingHumanInput.StepId, response);

        // Log each field for the grouped summary (mask sensitive values)
        if (_pendingHumanInput.Fields is not null)
        {
            foreach (var field in _pendingHumanInput.Fields)
            {
                var label = field.Description ?? field.Name;
                var value = _fieldValues.TryGetValue(field.Name, out var v) ? v : field.Default ?? "";
                var isSensitive = field.Name.Contains("key", StringComparison.OrdinalIgnoreCase)
                               || field.Name.Contains("secret", StringComparison.OrdinalIgnoreCase)
                               || field.Name.Contains("password", StringComparison.OrdinalIgnoreCase)
                               || field.Name.Contains("token", StringComparison.OrdinalIgnoreCase);
                _hitlLog.Add((label, isSensitive && !string.IsNullOrEmpty(value) ? "••••••••" : value));
            }
        }

        _pendingHumanInput = null;
        _fieldValues.Clear();
        StateHasChanged();
    }

    private string GetFieldValue(string name)
    {
        return _fieldValues.TryGetValue(name, out var v) ? v : "";
    }

    private void SetFieldValue(string name, string value)
    {
        _fieldValues[name] = value;
    }

    private void ReplaceLastAssistant(ChatMessageDto assistantMsg)
    {
        if (_active is null) return;
        for (var i = _active.Messages.Count - 1; i >= 0; i--)
        {
            if (string.Equals(_active.Messages[i].Role, "assistant", StringComparison.OrdinalIgnoreCase))
            {
                _active.Messages[i] = assistantMsg;
                if (_selectedTraceMessage is not null
                    && !string.IsNullOrWhiteSpace(_selectedTraceMessage.MessageId)
                    && string.Equals(_selectedTraceMessage.MessageId, assistantMsg.MessageId, StringComparison.Ordinal))
                {
                    _selectedTraceMessage = assistantMsg;
                }
                return;
            }
        }
    }

    private async Task NewChatAsync()
    {
        _cts?.Cancel();
        _error = "";
        _model.Prompt = "";

        var now = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        var session = new ChatSessionDto(
            Id: Guid.NewGuid().ToString("N"),
            Title: "New chat",
            UpdatedAtUnixMs: now,
            Messages: new List<ChatMessageDto>
            {
                    new("assistant", "New chat started. Ask me anything — I'll stream the answer as it's generated.", Guid.NewGuid().ToString("N"))
            },
            AgentName: _defaultAgentName);

        // Put it on top.
        _store.Sessions.Insert(0, session);
        _store = _store with { ActiveId = session.Id };
        _active = session;
        CloseTraceSidebar();

        CloseSidebar();

        await PersistAsync();
        _needsMarkdownEnhance = true;
        StateHasChanged();
        await ScrollToBottomAsync();
    }

    private async Task SelectChatAsync(string id)
    {
        if (_isStreaming) return;

        if (!string.Equals(_store.ActiveId, id, StringComparison.Ordinal))
        {
            _store = _store with { ActiveId = id };
            _active = _store.Sessions.FirstOrDefault(s => s.Id == id);
            CloseTraceSidebar();

            CloseSidebar();
            await PersistAsync();
            _needsMarkdownEnhance = true;
            StateHasChanged();
            await ScrollToBottomAsync();
        }
    }

    private async Task LoadStoreAsync()
    {
        var json = await Js.InvokeAsync<string?>("GnOuGo.Agent.storage.load", StorageKeyV2);
        if (!string.IsNullOrWhiteSpace(json))
        {
            var saved = JsonSerializer.Deserialize(json, ChatJsonContext.Default.ChatStoreDto);
            if (saved is not null)
                _store = saved;
            return;
        }

        var legacy = await Js.InvokeAsync<string?>("GnOuGo.Agent.storage.load", LegacyStorageKey);
        if (!string.IsNullOrWhiteSpace(legacy))
        {
            var msgs = JsonSerializer.Deserialize(legacy, ChatJsonContext.Default.ListChatMessageDto)
                       ?? new List<ChatMessageDto>();

            var now = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
            var session = new ChatSessionDto(
                Id: Guid.NewGuid().ToString("N"),
                Title: "Migrated sa-chat",
                UpdatedAtUnixMs: now,
                Messages: msgs);

            _store = new ChatStoreDto(session.Id, new List<ChatSessionDto> { session });

            await Js.InvokeVoidAsync("GnOuGo.Agent.storage.clear", LegacyStorageKey);
            await PersistAsync();
        }
    }

    private void EnsureActiveSession()
    {
        if (_store.Sessions.Count == 0)
        {
            var now = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
            var session = new ChatSessionDto(
                Id: Guid.NewGuid().ToString("N"),
                Title: "New chat",
                UpdatedAtUnixMs: now,
                Messages: new List<ChatMessageDto>
                {
                    new("assistant", "Hi! I'm GnOuGo.Agent. Ask me anything — I'll stream the answer as it's generated.", Guid.NewGuid().ToString("N"))
                },
                AgentName: _defaultAgentName);

            _store.Sessions.Add(session);
            _store = _store with { ActiveId = session.Id };
        }

        if (string.IsNullOrWhiteSpace(_store.ActiveId))
            _store = _store with { ActiveId = _store.Sessions[0].Id };

        _active = _store.Sessions.FirstOrDefault(s => s.Id == _store.ActiveId) ?? _store.Sessions[0];
        _store = _store with { ActiveId = _active.Id };
    }

    private bool SyncSessionsToDefaultAgent()
    {
        var changed = false;

        for (var i = 0; i < _store.Sessions.Count; i++)
        {
            var session = _store.Sessions[i];
            if (string.Equals(session.AgentName, _defaultAgentName, StringComparison.Ordinal))
                continue;

            _store.Sessions[i] = session with { AgentName = _defaultAgentName };
            changed = true;
        }

        if (_active is not null)
        {
            var updatedActive = _store.Sessions.FirstOrDefault(s => s.Id == _active.Id);
            if (updatedActive is not null)
                _active = updatedActive;
        }

        return changed;
    }

    private void TouchActive()
    {
        if (_active is null) return;
        var now = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        _active = _active with { UpdatedAtUnixMs = now };
        ReplaceSession(_active);
    }

    private void ReplaceSession(ChatSessionDto session)
    {
        for (var i = 0; i < _store.Sessions.Count; i++)
        {
            if (string.Equals(_store.Sessions[i].Id, session.Id, StringComparison.Ordinal))
            {
                _store.Sessions[i] = session;
                return;
            }
        }
    }

    private async Task PersistAsync()
    {
        var json = JsonSerializer.Serialize(_store, ChatJsonContext.Default.ChatStoreDto);
        await Js.InvokeVoidAsync("GnOuGo.Agent.storage.save", StorageKeyV2, json);
    }

    private void OpenTraceSidebar(ChatMessageDto msg)
    {
        _selectedTraceMessage = msg;
        _traceSidebarOpen = true;
    }

    private void CloseTraceSidebar()
    {
        _traceSidebarOpen = false;
        _selectedTraceMessage = null;
    }

    private Task CloseTraceSidebarAsync()
    {
        CloseTraceSidebar();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private static string FormatUpdatedAt(long unixMs)
    {
        if (unixMs <= 0) return "";
        var dt = DateTimeOffset.FromUnixTimeMilliseconds(unixMs).ToLocalTime();
        var now = DateTimeOffset.Now;
        if (dt.Date == now.Date) return dt.ToString("HH:mm");
        return dt.ToString("yyyy-MM-dd");
    }

    private async Task ScrollToBottomAsync()
    {
        try
        {
            await Js.InvokeVoidAsync("GnOuGo.Agent.scrollToBottom", "chatMessages");
        }
        catch (JSDisconnectedException)
        {
        }
        catch (InvalidOperationException ex) when (IsDeferredJavaScriptInterop(ex))
        {
        }
    }
}

