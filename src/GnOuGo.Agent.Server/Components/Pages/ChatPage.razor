    [JSInvokable]
    public Task NotifyFileUploadStarted(string clientId, string fileName, long sizeBytes)
    {
        var upload = FindComposerUpload(clientId);
        if (upload is null)
        {
            _composerUploads.Add(new ComposerUploadModel
            {
                ClientId = clientId,
                FileName = string.IsNullOrWhiteSpace(fileName) ? "document" : fileName,
                SizeBytes = sizeBytes,
                Progress = 0
            });
        }
        else
        {
            upload.FileName = string.IsNullOrWhiteSpace(fileName) ? upload.FileName : fileName;
            upload.SizeBytes = sizeBytes;
            upload.Progress = 0;
            upload.FileId = null;
            upload.Error = null;
        }

        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task NotifyFileUploadProgress(string clientId, int progress)
    {
        var upload = FindComposerUpload(clientId);
        if (upload is not null && !upload.IsCompleted)
        {
            upload.Progress = Math.Clamp(progress, 0, 99);
            StateHasChanged();
        }

        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task NotifyFileUploadCompleted(string clientId, string fileId)
    {
        var upload = FindComposerUpload(clientId);
        if (upload is not null)
        {
            upload.FileId = fileId;
            upload.Error = null;
            upload.Progress = 100;
            StateHasChanged();
        }

        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task NotifyFileUploadFailed(string clientId, string error)
    {
        var upload = FindComposerUpload(clientId);
        if (upload is not null)
        {
            upload.Error = string.IsNullOrWhiteSpace(error) ? "Upload failed." : error;
            upload.Progress = 100;
            StateHasChanged();
        }

        return Task.CompletedTask;
    }

    private ComposerUploadModel? FindComposerUpload(string clientId)
        => _composerUploads.FirstOrDefault(upload => string.Equals(upload.ClientId, clientId, StringComparison.Ordinal));

    private void RemoveComposerUpload(string clientId)
    {
        if (_isStreaming)
            return;

        _composerUploads.RemoveAll(upload => string.Equals(upload.ClientId, clientId, StringComparison.Ordinal));
    }

    private async Task<ChatMessageDto> AppendAssistantContentAsync(
        ChatMessageDto assistantMsg,
        string? incomingText,
        CancellationToken ct)
    {
        if (_active is null)
            return assistantMsg;

        var text = incomingText ?? "";
        if (string.IsNullOrWhiteSpace(text))
            return assistantMsg;

        var current = assistantMsg.Content;
        if (string.Equals(current, text, StringComparison.Ordinal))
            return assistantMsg;

        if (!string.IsNullOrEmpty(current) && text.StartsWith(current, StringComparison.Ordinal))
        {
            var delta = text[current.Length..];
            if (!string.IsNullOrEmpty(delta))
                await TypewriterAppendAsync(delta, assistantMsg, ct);
        }
        else if (!string.IsNullOrEmpty(current) && current.StartsWith(text, StringComparison.Ordinal))
        {
            return assistantMsg;
        }
        else
        {
            var separator = NeedsResponseSeparator(current, text) ? "\n\n" : "";
            await TypewriterAppendAsync(separator + text, assistantMsg, ct);
        }

        return _active.Messages.LastOrDefault(m =>
                   string.Equals(m.Role, "assistant", StringComparison.OrdinalIgnoreCase))
               ?? assistantMsg;
    }

    private static bool NeedsResponseSeparator(string current, string next)
    {
        if (string.IsNullOrWhiteSpace(current) || string.IsNullOrWhiteSpace(next))
            return false;

        return !char.IsWhiteSpace(current[^1])
            && !char.IsWhiteSpace(next[0]);
    }

    private async Task SendAsync()
    {
        if (_active is null) return;
        if (_isStreaming) return;
        if (HasBlockingUploads) return;

        _error = "";
        JsonObject? workflowInputs = null;
        var prompt = _model.Prompt.Trim();

        if (UseWorkflowInputComposer && _workflowInputSchema is not null)
        {
            if (!WorkflowInputComposer.TryBuildInputs(_workflowInputSchema, _workflowInputValues, out var builtInputs, out var inputErrors))
            {
                _error = string.Join(" ", inputErrors);
                return;
            }

            workflowInputs = builtInputs;
            prompt = WorkflowInputComposer.BuildPromptSummary(_workflowInputSchema, builtInputs);
        }

        if (string.IsNullOrWhiteSpace(prompt))
            return;

        var filesIds = UploadedFileIds;

        _model.Prompt = "";
        _composerUploads.Clear();
        if (UseWorkflowInputComposer)
            ResetWorkflowInputValues();
        var correlationId = ActivityTraceId.CreateRandom().ToHexString();

        // Add user message
        var userMsg = new ChatMessageDto("user", prompt, MessageId: Guid.NewGuid().ToString("N"), CorrelationId: correlationId);
        _active.Messages.Add(userMsg);

        // Placeholder assistant message
        var assistantMsg = new ChatMessageDto("assistant", "", MessageId: Guid.NewGuid().ToString("N"), CorrelationId: correlationId);
        _active.Messages.Add(assistantMsg);

        TouchActive();

        _isStreaming = true;
        _cts = new CancellationTokenSource();

        StateHasChanged();
        await ScrollToBottomAsync();

        try
        {
            var conversationId = string.IsNullOrWhiteSpace(_active.ConversationId) ? _active.Id : _active.ConversationId;
            await foreach (var evt in SmartFlow.ExecuteAsync(prompt, correlationId, agentName: null, filesIds, workflowInputs, conversationId, _cts.Token))
            {
                if (evt.Type is "animation.prepared" && evt.Animation?.Prepared is { } prepared)
                {
                    var execution = new ChatExecutionModel
                    {
                        CorrelationId = correlationId,
                        HostId = AnimationHostId(correlationId),
                        Prepared = prepared,
                        LaneCount = prepared.LaneCount,
                        NodeCount = prepared.NodeCount,
                        Status = "Running"
                    };
                    _executions[correlationId] = execution;
                    _activeExecutionCorrelationId = correlationId;
                    _selectedExecution = execution;
                    StateHasChanged();
                    continue;
                }

                if (evt.Type is "animation.scene.patch" && evt.Animation?.ScenePatch is { } patch)
                {
                    if (GetExecution(correlationId) is { } execution)
                    {
                        execution.PendingUpdates.Enqueue(new AnimationLiveUpdate { ScenePatch = patch });
                        execution.LastEventType = "scene patch";
                        execution.LaneCount += patch.Lanes.Count;
                        execution.NodeCount += patch.Nodes.Count;
                        StateHasChanged();
                    }
                    continue;
                }

                if (evt.Type is "animation.event" && evt.Animation?.Event is { } animationEvent)
                {
                    if (GetExecution(correlationId) is { } execution)
                    {
                        execution.PendingUpdates.Enqueue(new AnimationLiveUpdate { Event = animationEvent });
                        execution.LastEventType = animationEvent.Type;
                        ApplyExecutionStatus(execution, animationEvent);
                        StateHasChanged();
                    }
                    continue;
                }

                if (evt.Type is "trace.started")
                {
                    assistantMsg = assistantMsg with
                    {
                        CorrelationId = evt.CorrelationId ?? assistantMsg.CorrelationId,
                        TraceId = evt.TraceId
                    };
                    ReplaceLastAssistant(assistantMsg);
                    TouchActive();
                    StateHasChanged();
                    continue;
                }

                if (evt.Type is "conversation")
                {
                    var resolvedConversationId = evt.ConversationId ?? evt.Text;
                    if (!string.IsNullOrWhiteSpace(resolvedConversationId) && _active is not null)
                    {
                        _active = _active with { ConversationId = resolvedConversationId };
                        ReplaceSession(_active);
                    }
                    continue;
                }

                if (evt.Type.StartsWith("thinking:", StringComparison.Ordinal))
                {
                    var level = evt.Type.AsSpan(9).ToString(); // after "thinking:"

                    if (string.Equals(level, "response", StringComparison.OrdinalIgnoreCase))
                    {
                        // "response" level = final user-facing content (e.g. from configure-providers)
                        assistantMsg = await AppendAssistantContentAsync(assistantMsg, evt.Text, _cts.Token);
                    }
                    else
                    {
                        AddExecutionActivity(correlationId, level, evt.Text ?? "Workflow activity");
                        StateHasChanged();
                    }
                }
                else if (evt.Type is "answer" or "response")
                {
                    // Typewriter effect for the final answer
                    assistantMsg = await AppendAssistantContentAsync(assistantMsg, evt.Text, _cts.Token);
                }
                else if (evt.Type is "llm.chunk")
                {
                    // Intermediate LLM chunks — also typewriter
                    // (These are intermediate steps, not the final answer,
                    //  but we can show them to give feedback.)
                }
                else if (evt.Type.StartsWith("telemetry.", StringComparison.Ordinal))
                {
                    var liveStatus = FormatLiveTelemetryEvent(evt.Type, evt.Text);
                    if (!string.IsNullOrWhiteSpace(liveStatus))
                    {
                        var (workflowName, stepId) = ReadTelemetryIdentity(evt.Text);
                        AddExecutionActivity(correlationId, "telemetry", liveStatus, workflowName, stepId);
                        StateHasChanged();
                    }
                }
                else if (evt.Type is "error")
                {
                    // Detect HITL timeout and show a friendly message
                    var errText = evt.Text ?? "Unknown error";
                    if (errText.Contains("timed out", StringComparison.OrdinalIgnoreCase)
                        && errText.Contains("human", StringComparison.OrdinalIgnoreCase)
                        && _active is not null)
                    {
                        var timeoutMsg = new ChatMessageDto("assistant",
                            "⏱️ **Human input timed out.** The workflow was waiting for your response, "
                            + "but no input was received within the allowed time. "
                            + "Please try again — the workflow will re-prompt you for the required information.",
                            assistantMsg.MessageId,
                            assistantMsg.CorrelationId,
                            assistantMsg.TraceId);

                        // Replace the empty assistant placeholder (if any) instead of inserting alongside it
                        var replaced = false;
                        for (var i = _active.Messages.Count - 1; i >= 0; i--)
                        {
                            if (string.Equals(_active.Messages[i].Role, "assistant", StringComparison.OrdinalIgnoreCase)
                                && string.IsNullOrWhiteSpace(_active.Messages[i].Content))
                            {
                                _active.Messages[i] = timeoutMsg;
                                if (_selectedTraceMessage is not null
                                    && !string.IsNullOrWhiteSpace(_selectedTraceMessage.MessageId)
                                    && string.Equals(_selectedTraceMessage.MessageId, timeoutMsg.MessageId, StringComparison.Ordinal))
                                {
                                    _selectedTraceMessage = timeoutMsg;
                                }
                                replaced = true;
                                break;
                            }
                        }
                        if (!replaced)
                        {
                            _active.Messages.Add(timeoutMsg);
                            if (_selectedTraceMessage is not null
                                && !string.IsNullOrWhiteSpace(_selectedTraceMessage.MessageId)
                                && string.Equals(_selectedTraceMessage.MessageId, timeoutMsg.MessageId, StringComparison.Ordinal))
                            {
                                _selectedTraceMessage = timeoutMsg;
                            }
                        }

                        ResetHumanInputState();
                        if (GetExecution(correlationId) is { } timedOutExecution)
                            timedOutExecution.Status = "Failed";
                        StateHasChanged();
                        await ScrollToBottomAsync();
                    }
                    else
                    {
                        _error = errText;
                        if (GetExecution(correlationId) is { } failedExecution)
                            failedExecution.Status = "Failed";
                    }
                }
                else if (evt.Type is "agent_selected")
                {
                    if (!string.IsNullOrWhiteSpace(evt.Text))
                    {
                        _defaultAgentName = evt.Text;
                        await RefreshAvailableAgentsAsync();
                        SyncSessionsToDefaultAgent();
                        await RefreshWorkflowInputSchemaAsync();
                        StateHasChanged();
                    }
                }
                else if (evt.Type == "human_input_request")
                {
                    // Parse the human input request and show it in the UI
                    var requestJson = JsonNode.Parse(evt.Text ?? "{}")?.AsObject();
                    if (requestJson is not null)
                    {
                        var model = new HumanInputModel
                        {
                            RunId = ReadHumanInputString(requestJson["run_id"]) ?? "",
                            StepId = ReadHumanInputString(requestJson["step_id"]) ?? "",
                            Prompt = ReadHumanInputString(requestJson["prompt"]) ?? "",
                            Mode = ReadHumanInputString(requestJson["mode"]) ?? "text",
                            Context = FormatHumanInputContextNode(requestJson["context"]),
                        };

                        if (requestJson["choices"] is JsonArray choicesArr)
                            model.Choices = choicesArr.Select(c => ReadHumanInputString(c) ?? "").ToList();

                        if (requestJson["fields"] is JsonArray fieldsArr)
                        {
                            model.Fields = new List<HumanInputFieldModel>();
                            foreach (var fNode in fieldsArr)
                            {
                                if (fNode is not JsonObject fObj) continue;
                                var field = new HumanInputFieldModel
                                {
                                    Name = ReadHumanInputString(fObj["name"]) ?? "",
                                    Type = ReadHumanInputString(fObj["type"]) ?? "string",
                                    Required = ReadHumanInputBool(fObj["required"], defaultValue: false),
                                    Description = ReadHumanInputString(fObj["description"]),
                                    Options = fObj["options"] is JsonArray optionsArr
                                        ? optionsArr.Select(o => ReadHumanInputString(o) ?? "").Where(o => !string.IsNullOrWhiteSpace(o)).ToList()
                                        : null,
                                    Default = ReadHumanInputString(fObj["default"]),
                                };
                                model.Fields.Add(field);
                            }
                        }

                        SeedHumanInputFieldDefaults(model.Fields);

                        _pendingHumanInput = model;
                        if (GetExecution(correlationId) is { } waitingExecution)
                        {
                            waitingExecution.Status = "Waiting for you";
                            waitingExecution.IsExpanded = true;
                            _selectedExecution = waitingExecution;
                        }
                        _needsMarkdownEnhance = true;
                        StateHasChanged();
                        await ScrollToBottomAsync();
                    }
                }
            }

            // Update title if still default
            if (_active is not null &&
                (string.Equals(_active.Title, "New chat", StringComparison.OrdinalIgnoreCase) ||
                 string.Equals(_active.Title, "Migrated gnougo-chat", StringComparison.OrdinalIgnoreCase)))
            {
                try
                {
                    var title = await SmartFlow.SuggestTitleAsync(_active.Messages, _cts.Token);
                    if (!string.IsNullOrWhiteSpace(title))
                    {
                        _active = _active with { Title = title.Trim() };
                        ReplaceSession(_active);
                    }
                }
                catch (OperationCanceledException)
                {
                }
                catch (Exception)
                {
                    // Ignore title generation failures.
                }
            }
        }
        catch (OperationCanceledException)
        {
            // user hit Stop
            if (GetExecution(correlationId) is { } stoppedExecution)
                stoppedExecution.Status = "Stopped";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            if (GetExecution(correlationId) is { } failedExecution)
                failedExecution.Status = "Failed";
        }
        finally
        {
            _isStreaming = false;
            ResetHumanInputState();
            _cts?.Dispose();
            _cts = null;

            TouchActive();

            _needsMarkdownEnhance = true;
            StateHasChanged();
        }
    }

    private void Stop()
    {
        if (GetExecution(_activeExecutionCorrelationId) is { } execution)
        {
            execution.Status = "Stopped";
            execution.LastEventType = SimulationEventTypes.SimulationCancelled;
            execution.PendingUpdates.Enqueue(new AnimationLiveUpdate
            {
                Event = new SimulationEvent
                {
                    Type = SimulationEventTypes.SimulationCancelled,
                    TaskId = "task-root",
                    Status = SimulationStatus.Failed,
                    DurationMs = 700,
                    Message = "Workflow execution was stopped."
                }
            });
        }
        _cts?.Cancel();
    }

    private ChatExecutionModel? GetExecution(string? correlationId)
        => !string.IsNullOrWhiteSpace(correlationId)
           && _executions.TryGetValue(correlationId, out var execution)
            ? execution
            : null;

    private static string AnimationHostId(string correlationId)
        => $"workflow-animation-{correlationId}";

    private void AddExecutionActivity(
        string correlationId,
        string level,
        string message,
        string? workflowName = null,
        string? stepId = null)
    {
        if (GetExecution(correlationId) is not { } execution
            || string.IsNullOrWhiteSpace(message))
            return;

        execution.Activity.Add(new ExecutionActivityItem(
            DateTimeOffset.UtcNow,
            string.IsNullOrWhiteSpace(level) ? "info" : level.ToLowerInvariant(),
            message,
            workflowName,
            stepId));
        if (execution.Activity.Count > 200)
            execution.Activity.RemoveRange(0, execution.Activity.Count - 200);
        if (ReferenceEquals(_selectedExecution, execution))
            _selectedExecution = execution;
    }

    private static (string? WorkflowName, string? StepId) ReadTelemetryIdentity(string? payload)
    {
        if (string.IsNullOrWhiteSpace(payload))
            return (null, null);
        try
        {
            var obj = JsonNode.Parse(payload)?.AsObject();
            return (
                ReadHumanInputString(obj?["workflow.name"]),
                ReadHumanInputString(obj?["step.id"]));
        }
        catch (JsonException)
        {
            return (null, null);
        }
    }

    private void ApplyExecutionStatus(ChatExecutionModel execution, SimulationEvent animationEvent)
    {
        execution.Status = animationEvent.Type switch
        {
            SimulationEventTypes.HumanInputWaiting => "Waiting for you",
            SimulationEventTypes.HumanInputResumed => "Running",
            SimulationEventTypes.SimulationCancelled => "Stopped",
            SimulationEventTypes.SimulationCompleted when animationEvent.Status == SimulationStatus.Failed => "Failed",
            SimulationEventTypes.SimulationCompleted => "Completed",
            _ when animationEvent.Status == SimulationStatus.Failed => "Failed",
            _ => execution.Status
        };

        if (!string.IsNullOrWhiteSpace(animationEvent.Message))
        {
            AddExecutionActivity(
                execution.CorrelationId,
                animationEvent.Status == SimulationStatus.Failed ? "error" : "animation",
                animationEvent.Message,
                animationEvent.WorkflowName,
                animationEvent.StepId);
        }

    }

    private async Task FlushAnimationInteropAsync()
    {
        if (!await _animationInteropGate.WaitAsync(0))
            return;

        try
        {
            foreach (var execution in _executions.Values.ToArray())
            {
                try
                {
                    if (execution.NeedsMount)
                    {
                        var mounted = await Js.InvokeAsync<bool>(
                            "GnOuGo.Agent.workflowAnimation.mount",
                            execution.HostId,
                            execution.Prepared);
                        if (!mounted)
                        {
                            ScheduleAnimationInteropRetry();
                            return;
                        }
                        execution.NeedsMount = false;
                    }

                    while (execution.PendingUpdates.TryPeek(out var update))
                    {
                        if (update.ScenePatch is not null)
                        {
                            var applied = await Js.InvokeAsync<bool>(
                                "GnOuGo.Agent.workflowAnimation.applyPatch",
                                execution.HostId,
                                update.ScenePatch);
                            if (!applied)
                            {
                                execution.NeedsMount = true;
                                ScheduleAnimationInteropRetry();
                                return;
                            }
                        }
                        if (update.Event is not null)
                        {
                            var applied = await Js.InvokeAsync<bool>(
                                "GnOuGo.Agent.workflowAnimation.applyEvent",
                                execution.HostId,
                                update.Event);
                            if (!applied)
                            {
                                execution.NeedsMount = true;
                                ScheduleAnimationInteropRetry();
                                return;
                            }
                        }
                        execution.PendingUpdates.Dequeue();
                    }
                }
                catch (JSDisconnectedException)
                {
                    return;
                }
                catch (InvalidOperationException ex) when (IsDeferredJavaScriptInterop(ex))
                {
                    return;
                }
                catch (JSException ex)
                {
                    execution.Status = "Animation error";
                    execution.LastEventType = ex.Message;
                    ScheduleAnimationInteropRetry();
                    return;
                }
            }
        }
        finally
        {
            _animationInteropGate.Release();
        }

        if (_executions.Values.Any(static execution =>
                execution.NeedsMount || execution.PendingUpdates.Count > 0))
            ScheduleAnimationInteropRetry();
    }

    private void ScheduleAnimationInteropRetry()
    {
        if (_animationInteropRetryPending || _disposed)
            return;

        _animationInteropRetryPending = true;
        _ = RetryAnimationInteropAsync();
    }

    private async Task RetryAnimationInteropAsync()
    {
        await Task.Delay(120);
        if (_disposed)
            return;

        await InvokeAsync(() =>
        {
            _animationInteropRetryPending = false;
            StateHasChanged();
        });
    }

