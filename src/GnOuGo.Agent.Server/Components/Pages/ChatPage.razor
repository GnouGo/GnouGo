    private void RecordHumanInput(string question, string answer)
    {
        if (GetExecution(_activeExecutionCorrelationId) is { } execution)
        {
            execution.HumanInputSummaries.Add((question, answer));
            execution.Status = "Resuming";
        }
    }

    private void SubmitHumanInputChoice(string choice)
    {
        if (_pendingHumanInput is null) return;

        var response = new JsonObject { ["response"] = choice };
        HumanInputProvider.TrySubmitResponse(_pendingHumanInput.RunId, _pendingHumanInput.StepId, response);

        RecordHumanInput(_pendingHumanInput.Prompt, choice);

        ResetHumanInputState();
        StateHasChanged();
    }

    private void SubmitHumanInputText()
    {
        if (_pendingHumanInput is null) return;

        var answer = _pendingHumanInput.ResponseText.Trim();
        if (string.IsNullOrWhiteSpace(answer)) return;

        var response = new JsonObject { ["response"] = answer };
        HumanInputProvider.TrySubmitResponse(_pendingHumanInput.RunId, _pendingHumanInput.StepId, response);

        RecordHumanInput(_pendingHumanInput.Prompt, answer);

        ResetHumanInputState();
        StateHasChanged();
    }

    private void SubmitHumanInputFields()
    {
        if (_pendingHumanInput is null) return;

        var response = new JsonObject();
        if (_pendingHumanInput.Fields is not null)
        {
            foreach (var field in _pendingHumanInput.Fields)
            {
                var value = _fieldValues.TryGetValue(field.Name, out var v) ? v : "";
                response[field.Name] = BuildHumanInputFieldValue(field, value, GetSelectedFieldOptions(field));
            }
        }

        HumanInputProvider.TrySubmitResponse(_pendingHumanInput.RunId, _pendingHumanInput.StepId, response);

        // Log each field for the grouped summary (mask sensitive values)
        if (_pendingHumanInput.Fields is not null)
        {
            foreach (var field in _pendingHumanInput.Fields)
            {
                var label = field.Description ?? field.Name;
                var value = FormatHumanInputLogValue(field);
                var isSensitive = field.Name.Contains("key", StringComparison.OrdinalIgnoreCase)
                               || field.Name.Contains("secret", StringComparison.OrdinalIgnoreCase)
                               || field.Name.Contains("password", StringComparison.OrdinalIgnoreCase)
                               || field.Name.Contains("token", StringComparison.OrdinalIgnoreCase);
                RecordHumanInput(label, isSensitive && !string.IsNullOrEmpty(value) ? "••••••••" : value);
            }
        }

        ResetHumanInputState();
        StateHasChanged();
    }

    private static JsonNode? BuildHumanInputFieldValue(HumanInputFieldModel field, string value, IReadOnlyCollection<string> selectedOptions)
    {
        if (IsMultiOptionField(field))
            return new JsonArray(selectedOptions.Select(option => (JsonNode?)JsonValue.Create(option)).ToArray());
        if (field.Type.Equals("integer", StringComparison.OrdinalIgnoreCase)
            && int.TryParse(value, out var intValue))
            return JsonValue.Create(intValue);
        if (field.Type.Equals("number", StringComparison.OrdinalIgnoreCase)
            && double.TryParse(value, out var numberValue))
            return JsonValue.Create(numberValue);
        if (field.Type.Equals("boolean", StringComparison.OrdinalIgnoreCase))
            return JsonValue.Create(value.Equals("true", StringComparison.OrdinalIgnoreCase)
                                    || value == "1"
                                    || value.Equals("yes", StringComparison.OrdinalIgnoreCase));
        return JsonValue.Create(value);
    }

    private string FormatHumanInputLogValue(HumanInputFieldModel field)
    {
        if (IsMultiOptionField(field))
            return string.Join(", ", GetSelectedFieldOptions(field));
        return _fieldValues.TryGetValue(field.Name, out var value) ? value : field.Default ?? "";
    }

    private static string? FormatLiveTelemetryEvent(string type, string? payload)
    {
        if (string.IsNullOrWhiteSpace(payload))
            return null;

        JsonObject? obj;
        try
        {
            obj = JsonNode.Parse(payload)?.AsObject();
        }
        catch (JsonException)
        {
            return null;
        }

        if (obj is null)
            return null;

        return type switch
        {
            "telemetry.step.start" => $"Starting {ReadHumanInputString(obj["step.id"]) ?? "step"} ({ReadHumanInputString(obj["step.type"]) ?? "unknown"})",
            "telemetry.step.end" => FormatLiveStepEnd(obj),
            "telemetry.span.start" => $"Phase started: {ReadHumanInputString(obj["phase"]) ?? ReadHumanInputString(obj["span.name"]) ?? "internal"}",
            "telemetry.span.end" => FormatLiveSpanEnd(obj),
            _ => null
        };
    }

    private static string FormatLiveStepEnd(JsonObject obj)
    {
        var stepId = ReadHumanInputString(obj["step.id"]) ?? "step";
        var status = ReadHumanInputString(obj["status"]) ?? "completed";
        var duration = FormatLiveDuration(obj["duration.ms"]);
        return string.IsNullOrWhiteSpace(duration)
            ? $"{stepId}: {status}"
            : $"{stepId}: {status} in {duration}";
    }

    private static string FormatLiveSpanEnd(JsonObject obj)
    {
        var phase = ReadHumanInputString(obj["phase"]) ?? ReadHumanInputString(obj["span.name"]) ?? "internal";
        var success = ReadHumanInputBool(obj["success"], defaultValue: true);
        var duration = FormatLiveDuration(obj["duration.ms"]);
        var status = success ? "completed" : "failed";
        return string.IsNullOrWhiteSpace(duration)
            ? $"Phase {status}: {phase}"
            : $"Phase {status}: {phase} in {duration}";
    }

    private static string? FormatLiveDuration(JsonNode? node)
    {
        double? ms = node switch
        {
            JsonValue value when value.TryGetValue<double>(out var d) => d,
            JsonValue value when value.TryGetValue<long>(out var l) => l,
            JsonValue value when value.TryGetValue<string>(out var s)
                && double.TryParse(s, NumberStyles.Float, CultureInfo.InvariantCulture, out var parsed) => parsed,
            _ => null
        };

        if (!ms.HasValue)
            return null;

        return ms.Value >= 1000
            ? $"{ms.Value / 1000:0.0}s"
            : $"{ms.Value:0}ms";
    }

    private static string? ReadHumanInputString(JsonNode? node)
    {
        if (node is not JsonValue value)
            return null;
        if (value.TryGetValue<string>(out var stringValue))
            return stringValue;
        if (value.TryGetValue<bool>(out var boolValue))
            return boolValue ? "true" : "false";
        if (value.TryGetValue<int>(out var intValue))
            return intValue.ToString(CultureInfo.InvariantCulture);
        if (value.TryGetValue<long>(out var longValue))
            return longValue.ToString(CultureInfo.InvariantCulture);
        if (value.TryGetValue<double>(out var doubleValue))
            return doubleValue.ToString(CultureInfo.InvariantCulture);
        if (value.TryGetValue<decimal>(out var decimalValue))
            return decimalValue.ToString(CultureInfo.InvariantCulture);
        return null;
    }

    private static bool ReadHumanInputBool(JsonNode? node, bool defaultValue)
    {
        if (node is not JsonValue value)
            return defaultValue;
        if (value.TryGetValue<bool>(out var boolValue))
            return boolValue;
        if (value.TryGetValue<string>(out var stringValue))
        {
            var normalized = stringValue.Trim();
            if (bool.TryParse(normalized, out var parsed))
                return parsed;
            if (normalized.Equals("1", StringComparison.OrdinalIgnoreCase)
                || normalized.Equals("yes", StringComparison.OrdinalIgnoreCase)
                || normalized.Equals("y", StringComparison.OrdinalIgnoreCase))
                return true;
            if (normalized.Equals("0", StringComparison.OrdinalIgnoreCase)
                || normalized.Equals("no", StringComparison.OrdinalIgnoreCase)
                || normalized.Equals("n", StringComparison.OrdinalIgnoreCase))
                return false;
        }
        if (value.TryGetValue<int>(out var intValue))
            return intValue != 0;
        if (value.TryGetValue<long>(out var longValue))
            return longValue != 0L;
        return defaultValue;
    }

    private string GetFieldValue(string name)
    {
        return _fieldValues.TryGetValue(name, out var v) ? v : "";
    }

    private void SetFieldValue(string name, string value)
    {
        _fieldValues[name] = value;
    }

    private void ReplaceLastAssistant(ChatMessageDto assistantMsg)
    {
        if (_active is null) return;
        for (var i = _active.Messages.Count - 1; i >= 0; i--)
        {
            if (string.Equals(_active.Messages[i].Role, "assistant", StringComparison.OrdinalIgnoreCase))
            {
                _active.Messages[i] = assistantMsg;
                if (_selectedTraceMessage is not null
                    && !string.IsNullOrWhiteSpace(_selectedTraceMessage.MessageId)
                    && string.Equals(_selectedTraceMessage.MessageId, assistantMsg.MessageId, StringComparison.Ordinal))
                {
                    _selectedTraceMessage = assistantMsg;
                }
                return;
            }
        }
    }

    private async Task NewChatAsync()
    {
        _cts?.Cancel();
        _error = "";
        _model.Prompt = "";
        _composerUploads.Clear();

        var now = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        var sessionId = Guid.NewGuid().ToString("N");
        var session = new ChatSessionDto(
            Id: sessionId,
            Title: "New chat",
            UpdatedAtUnixMs: now,
            Messages: new List<ChatMessageDto>
            {
                    new("assistant", "New chat started. Ask me anything — I'll stream the answer as it's generated.", Guid.NewGuid().ToString("N"))
            },
            AgentName: _defaultAgentName,
            ConversationId: sessionId);

        // Put it on top.
        _store.Sessions.Insert(0, session);
        _store = _store with { ActiveId = session.Id };
        _active = session;
        CloseTraceSidebar();

        CloseSidebar();

        _needsMarkdownEnhance = true;
        StateHasChanged();
        await ScrollToBottomAsync();
    }

    private async Task SelectChatAsync(string id)
    {
        if (_isStreaming) return;

        if (!string.Equals(_store.ActiveId, id, StringComparison.Ordinal))
        {
            _store = _store with { ActiveId = id };
            _active = _store.Sessions.FirstOrDefault(s => s.Id == id);
            if (_active is { Messages.Count: 0 } && await TryHydrateSessionMessagesAsync(_active))
            {
                _active = _store.Sessions.FirstOrDefault(s => s.Id == id);
            }
            CloseTraceSidebar();

            CloseSidebar();
            _needsMarkdownEnhance = true;
            StateHasChanged();
            await ScrollToBottomAsync();
        }
    }

    private async Task<bool> MergeServerConversationsAsync()
    {
        try
        {
            var http = HttpClientFactory.CreateClient();
            var conversationsUri = Navigation.ToAbsoluteUri("api/chat/conversations");
            var conversations = await http.GetFromJsonAsync(conversationsUri, ChatJsonContext.Default.ListChatConversationSummaryDto)
                                ?? new List<ChatConversationSummaryDto>();

            var changed = false;
            foreach (var conversation in conversations)
            {
                var existingIndex = _store.Sessions.FindIndex(session =>
                    string.Equals(session.ConversationId, conversation.ConversationId, StringComparison.Ordinal)
                    || string.Equals(session.Id, conversation.ConversationId, StringComparison.Ordinal));

                if (existingIndex >= 0)
                {
                    var existing = _store.Sessions[existingIndex];
                    var title = IsDefaultChatTitle(existing.Title) ? conversation.Title : existing.Title;
                    var updatedAt = Math.Max(existing.UpdatedAtUnixMs, conversation.UpdatedAtUnixMs);
                    var updated = existing with
                    {
                        Title = title,
                        UpdatedAtUnixMs = updatedAt,
                        ConversationId = conversation.ConversationId
                    };

                    if (!ReferenceEquals(existing, updated) && !Equals(existing, updated))
                    {
                        _store.Sessions[existingIndex] = updated;
                        changed = true;
                    }

                    continue;
                }

                _store.Sessions.Add(new ChatSessionDto(
                    Id: conversation.ConversationId,
                    Title: conversation.Title,
                    UpdatedAtUnixMs: conversation.UpdatedAtUnixMs,
                    Messages: new List<ChatMessageDto>(),
                    AgentName: _defaultAgentName,
                    ConversationId: conversation.ConversationId));
                changed = true;
            }

            if (changed)
                _store.Sessions.Sort(static (left, right) => right.UpdatedAtUnixMs.CompareTo(left.UpdatedAtUnixMs));

            return changed;
        }
        catch (HttpRequestException)
        {
            return false;
        }
        catch (JsonException)
        {
            return false;
        }
        catch (InvalidOperationException)
        {
            return false;
        }
    }

    private async Task<bool> TryHydrateSessionMessagesAsync(ChatSessionDto session)
    {
        var conversationId = string.IsNullOrWhiteSpace(session.ConversationId) ? session.Id : session.ConversationId;
        if (string.IsNullOrWhiteSpace(conversationId))
            return false;

        try
        {
            var http = HttpClientFactory.CreateClient();
            var conversationUri = Navigation.ToAbsoluteUri($"api/chat/conversations/{Uri.EscapeDataString(conversationId)}");
            var hydrated = await http.GetFromJsonAsync(conversationUri, ChatJsonContext.Default.ChatSessionDto);
            if (hydrated is null)
                return false;

            var updated = session with
            {
                Title = IsDefaultChatTitle(session.Title) ? hydrated.Title : session.Title,
                UpdatedAtUnixMs = Math.Max(session.UpdatedAtUnixMs, hydrated.UpdatedAtUnixMs),
                Messages = hydrated.Messages,
                ConversationId = hydrated.ConversationId ?? conversationId
            };

            ReplaceSession(updated);
            if (string.Equals(_store.ActiveId, session.Id, StringComparison.Ordinal))
                _active = updated;

            return true;
        }
        catch (HttpRequestException)
        {
            return false;
        }
        catch (JsonException)
        {
            return false;
        }
        catch (InvalidOperationException)
        {
            return false;
        }
    }

    private void EnsureActiveSession()
    {
        if (_store.Sessions.Count == 0)
        {
            var now = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
            var sessionId = Guid.NewGuid().ToString("N");
            var session = new ChatSessionDto(
                Id: sessionId,
                Title: "New chat",
                UpdatedAtUnixMs: now,
                Messages: new List<ChatMessageDto>
                {
                    new("assistant", "Hi! I'm GnOuGo.Agent. Ask me anything — I'll stream the answer as it's generated.", Guid.NewGuid().ToString("N"))
                },
                AgentName: _defaultAgentName,
                ConversationId: sessionId);

            _store.Sessions.Add(session);
            _store = _store with { ActiveId = session.Id };
        }

        if (string.IsNullOrWhiteSpace(_store.ActiveId))
            _store = _store with { ActiveId = _store.Sessions[0].Id };

        _active = _store.Sessions.FirstOrDefault(s => s.Id == _store.ActiveId) ?? _store.Sessions[0];
        if (string.IsNullOrWhiteSpace(_active.ConversationId))
        {
            _active = _active with { ConversationId = _active.Id };
            ReplaceSession(_active);
        }
        _store = _store with { ActiveId = _active.Id };
    }

    private bool SyncSessionsToDefaultAgent()
    {
        var changed = false;

        for (var i = 0; i < _store.Sessions.Count; i++)
        {
            var session = _store.Sessions[i];
            if (string.Equals(session.AgentName, _defaultAgentName, StringComparison.Ordinal))
                continue;

            _store.Sessions[i] = session with { AgentName = _defaultAgentName };
            changed = true;
        }

        if (_active is not null)
        {
            var updatedActive = _store.Sessions.FirstOrDefault(s => s.Id == _active.Id);
            if (updatedActive is not null)
                _active = updatedActive;
        }

        return changed;
    }

    private void TouchActive()
    {
        if (_active is null) return;
        var now = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        _active = _active with { UpdatedAtUnixMs = now };
        ReplaceSession(_active);
    }

    private void ReplaceSession(ChatSessionDto session)
    {
        for (var i = 0; i < _store.Sessions.Count; i++)
        {
            if (string.Equals(_store.Sessions[i].Id, session.Id, StringComparison.Ordinal))
            {
                _store.Sessions[i] = session;
                return;
            }
        }
    }

    private static bool IsDefaultChatTitle(string? title)
        => string.IsNullOrWhiteSpace(title)
           || string.Equals(title, "New chat", StringComparison.OrdinalIgnoreCase)
           || string.Equals(title, "Migrated gnougo-chat", StringComparison.OrdinalIgnoreCase)
           || string.Equals(title, "Chat", StringComparison.OrdinalIgnoreCase);

    private void OpenTraceSidebar(ChatMessageDto msg)
    {
        _executionSidebarOpen = false;
        _selectedTraceMessage = msg;
        _traceSidebarOpen = true;
    }

    private void CloseTraceSidebar()
    {
        _traceSidebarOpen = false;
        _selectedTraceMessage = null;
    }

    private Task CloseTraceSidebarAsync()
    {
        CloseTraceSidebar();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private static string FormatUpdatedAt(long unixMs)
    {
        if (unixMs <= 0) return "";
        var dt = DateTimeOffset.FromUnixTimeMilliseconds(unixMs).ToLocalTime();
        var now = DateTimeOffset.Now;
        if (dt.Date == now.Date) return dt.ToString("HH:mm");
        return dt.ToString("yyyy-MM-dd");
    }

    private static string FormatBytes(long bytes)
    {
        string[] units = ["B", "KB", "MB", "GB"];
        var value = Math.Max(0, bytes);
        var unit = 0;
        double display = value;
        while (display >= 1024 && unit < units.Length - 1)
        {
            display /= 1024;
            unit++;
        }

        return unit == 0 ? $"{value} {units[unit]}" : $"{display:0.##} {units[unit]}";
    }

    private static string ShortId(string? id)
        => string.IsNullOrWhiteSpace(id) ? "" : id.Length <= 8 ? id : id[..8];

