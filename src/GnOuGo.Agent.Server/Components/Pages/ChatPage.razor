    private void SeedHumanInputFieldDefaults(IReadOnlyList<HumanInputFieldModel>? fields)
    {
        _fieldValues.Clear();
        _multiFieldValues.Clear();
        if (fields is null)
            return;

        foreach (var field in fields)
        {
            if (IsMultiOptionField(field))
            {
                var selected = ParseMultiOptionDefault(field);
                if (selected.Count > 0)
                    _multiFieldValues[field.Name] = selected;
                continue;
            }

            if (!string.IsNullOrEmpty(field.Default))
            {
                _fieldValues[field.Name] = FormatEditableFieldValue(field, field.Default);
                continue;
            }

            if ((IsSelectField(field) || IsRadioField(field)) && field.Options is { Count: > 0 })
                _fieldValues[field.Name] = field.Options[0];
            else if (field.Type.Equals("boolean", StringComparison.OrdinalIgnoreCase))
                _fieldValues[field.Name] = "false";
        }
    }

    private static HashSet<string> ParseMultiOptionDefault(HumanInputFieldModel field)
    {
        var selected = new HashSet<string>(StringComparer.Ordinal);
        if (string.IsNullOrWhiteSpace(field.Default))
            return selected;

        if (TryParseJsonArray(field.Default, out var jsonArray))
        {
            foreach (var item in jsonArray)
            {
                var value = ReadHumanInputString(item);
                if (!string.IsNullOrWhiteSpace(value))
                    selected.Add(value);
            }
            return selected;
        }

        foreach (var value in field.Default.Split([',', ';', '\n'], StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries))
            selected.Add(value);

        return selected;
    }

    private static bool TryParseJsonArray(string value, out JsonArray jsonArray)
    {
        jsonArray = new JsonArray();
        try
        {
            if (JsonNode.Parse(value) is JsonArray parsed)
            {
                jsonArray = parsed;
                return true;
            }
        }
        catch (JsonException)
        {
        }

        return false;
    }

