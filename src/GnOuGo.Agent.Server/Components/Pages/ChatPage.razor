@page "/"
@using System.Diagnostics
@using System.Text.Json
@using System.Text.Json.Nodes
@using System.Threading
@using Microsoft.JSInterop
@using GnOuGo.Agent.Server.Components.Tracing
@implements IAsyncDisposable

@inject IJSRuntime Js
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject SmartFlowService SmartFlow
@inject AgentHumanInputProvider HumanInputProvider
@inject AgentUserConfigMcpClient UserConfigClient
@inject AppVersionInfo VersionInfo

<div class="gnougo-app">
    <aside class="gnougo-app__sidebar gnougo-sidebar @( _sidebarOpen ? "gnougo-sidebar--open" : "")">
        <div class="gnougo-sidebar__header">
            <div class="gnougo-sidebar__brand">
                <img class="gnougo-sidebar__logo" src="assets/gnougo-agent-logo.png" alt="GnOuGo.Agent" />
                <div class="gnougo-sidebar__brand-text">
                    <div class="gnougo-sidebar__title">GnOuGo.Agent</div>
                    <div class="gnougo-sidebar__subtitle">Chats stored locally</div>
                </div>
            </div>

            <button class="gnougo-sidebar__new" @onclick="NewChatAsync" type="button" title="New chat">
                <span class="gnougo-sidebar__new-icon">＋</span>
                <span class="gnougo-sidebar__new-text">New chat</span>
            </button>

            <button class="gnougo-sidebar__close" @onclick="ToggleSidebar" type="button" title="Close">
                ✕
            </button>
        </div>

        <nav class="gnougo-sidebar__list" aria-label="Chats">
            @if (_store.Sessions.Count == 0)
            {
                <div class="gnougo-sidebar__empty">No chats yet.</div>
            }
            else
            {
                @foreach (var s in _store.Sessions.OrderByDescending(x => x.UpdatedAtUnixMs))
                {
                    var isActive = string.Equals(_store.ActiveId, s.Id, StringComparison.Ordinal);
                    <button class="gnougo-sidebar__item @(isActive ? "gnougo-sidebar__item--active" : "")"
                            @onclick="@(() => SelectChatAsync(s.Id))"
                            type="button">
                        <div class="gnougo-sidebar__item-title">@s.Title</div>
                        <div class="gnougo-sidebar__item-meta">@FormatUpdatedAt(s.UpdatedAtUnixMs)</div>
                    </button>
                }
            }
        </nav>

        <div class="gnougo-sidebar__footer">
            <div class="gnougo-sidebar__hint">
                Tip: your history is stored in <span class="gnougo-sidebar__hint-strong">localStorage</span>.
            </div>
            <div class="gnougo-sidebar__version" title="@DisplayVersionTitle">v@(DisplayVersion)</div>
        </div>
    </aside>

    <main class="gnougo-app__main gnougo-chat">
        <header class="gnougo-chat__topbar">
            <button class="gnougo-chat__menu" @onclick="ToggleSidebar" type="button" title="Menu">
                ☰
            </button>

            <div class="gnougo-chat__topbar-title">
                @if (!string.IsNullOrWhiteSpace(_defaultAgentName))
                {
                    <span class="gnougo-chat__agent-badge" title="Active agent">🤖 @_defaultAgentName</span>
                    <span style="margin: 0 8px; opacity: 0.4;">|</span>
                }
                @(_active?.Title ?? "Chat")
            </div>

            <div class="gnougo-chat__topbar-actions">
                <label for="chatAgentSelect" class="gnougo-chat__agent-select-label">Agent</label>
                <select id="chatAgentSelect"
                        class="gnougo-chat__agent-select"
                        title="Select default agent"
                        disabled="@(_isStreaming || _agentsLoading || _availableAgents.Count == 0)"
                        value="@(_defaultAgentName ?? string.Empty)"
                        @onchange="OnAgentSelectionChangedAsync">
                    @if (_availableAgents.Count == 0)
                    {
                        <option value="">No agents</option>
                    }
                    else
                    {
                        @foreach (var agent in _availableAgents)
                        {
                            <option value="@agent">@agent</option>
                        }
                    }
                </select>
                @if (_isStreaming)
                {
                    <div class="gnougo-chat__streaming" title="Streaming…">
                        <span class="gnougo-chat__streaming-dot"></span>
                        Streaming…
                    </div>
                }
            </div>
        </header>

        <section class="gnougo-chat__messages" id="chatMessages">
            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="gnougo-chat__error">@_error</div>
            }

            @if (_active is null || _active.Messages.Count == 0)
            {
                <div class="gnougo-chat__empty">
                    <div class="gnougo-chat__empty-title">Start a new chat</div>
                    <div class="gnougo-chat__empty-subtitle">Your messages and history stay in your browser.</div>
                </div>
            }
            else
            {
                @foreach (var msg in _active.Messages)
                {
                    var isUser = string.Equals(msg.Role, "user", StringComparison.OrdinalIgnoreCase);
                    var isThinking = string.Equals(msg.Role, "thinking", StringComparison.OrdinalIgnoreCase);
                    var isThought = string.Equals(msg.Role, "thought", StringComparison.OrdinalIgnoreCase);

                    @if (isThinking || isThought)
                    {
                        <article class="gnougo-chat__message @(isThought ? "gnougo-chat__message--thought" : "gnougo-chat__message--thinking")">
                            <div class="gnougo-chat__thinking">
                                <span class="gnougo-chat__thinking-icon">💭</span>
                                <span class="gnougo-chat__thinking-text">@msg.Content</span>
                            </div>
                        </article>
                    }
                    else
                    {
                        <article class="gnougo-chat__message @(isUser ? "gnougo-chat__message--user" : "gnougo-chat__message--assistant")">
                            <div class="gnougo-chat__bubble">
                                <div class="gnougo-chat__bubble-meta">
                                    <span class="gnougo-chat__bubble-role">@((isUser ? "You" : "GnOuGo.Agent"))</span>
                                    @if (!isUser)
                                    {
                                        var isTraceSelected = ReferenceEquals(_selectedTraceMessage, msg)
                                                              || (!string.IsNullOrWhiteSpace(_selectedTraceMessage?.MessageId)
                                                                  && string.Equals(_selectedTraceMessage?.MessageId, msg.MessageId, StringComparison.Ordinal));
                                        <button class="gnougo-chat__bubble-action @(isTraceSelected && _traceSidebarOpen ? "gnougo-chat__bubble-action--active" : "")"
                                                type="button"
                                                title="Open trace debug sidebar"
                                                @onclick="() => OpenTraceSidebar(msg)">
                                            🔎 Trace
                                        </button>
                                    }
                                </div>

                                <MarkdownContent Class="gnougo-chat__bubble-text" Content="@msg.Content" />
                            </div>
                        </article>
                    }
                }
            }

            @if (_pendingHumanInput is not null)
            {
                <article class="gnougo-chat__message gnougo-chat__message--assistant">
                    <div class="gnougo-chat__bubble">
                        <div class="gnougo-chat__bubble-meta">
                            <span class="gnougo-chat__bubble-role">⚙️ Configuration</span>
                        </div>
                        <div class="gnougo-chat__bubble-text">
                            <p><strong>@_pendingHumanInput.Prompt</strong></p>

                            @if (!string.IsNullOrWhiteSpace(_pendingHumanInput.Context))
                            {
                                <MarkdownContent Class="gnougo-hitl-context" Content="@FormatHumanInputContextAsMarkdown(_pendingHumanInput.Context)" />
                            }

                            @if (_pendingHumanInput.Choices is { Count: > 0 })
                            {
                                <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-top: 8px;">
                                    @foreach (var choice in _pendingHumanInput.Choices)
                                    {
                                        var c = choice;
                                        <button class="gnougo-composer__send"
                                                type="button"
                                                style="min-width: 80px;"
                                                @onclick="@(() => SubmitHumanInputChoice(c))">
                                            @c
                                        </button>
                                    }
                                </div>
                            }
                            else if (_pendingHumanInput.Fields is { Count: > 0 })
                            {
                                <div style="margin-top: 8px;">
                                    @foreach (var field in _pendingHumanInput.Fields)
                                    {
                                        <div style="margin-bottom: 8px;">
                                            <label style="display: block; font-weight: 600; margin-bottom: 2px;">
                                                @field.Name
                                                @if (field.Required) { <span style="color: #e74c3c;">*</span> }
                                            </label>
                                            @if (!string.IsNullOrWhiteSpace(field.Description))
                                            {
                                                <div style="font-size: 0.8em; opacity: 0.7; margin-bottom: 2px;">@field.Description</div>
                                            }
                                            @if (string.Equals(field.Type, "select", StringComparison.OrdinalIgnoreCase) && field.Options is { Count: > 0 })
                                            {
                                                <select class="gnougo-composer__input"
                                                        style="width: 100%; padding: 6px 10px; border-radius: 6px;"
                                                        value="@GetFieldValue(field.Name)"
                                                        @onchange="@(e => SetFieldValue(field.Name, e.Value?.ToString() ?? ""))">
                                                    @foreach (var option in field.Options)
                                                    {
                                                        <option value="@option">@option</option>
                                                    }
                                                </select>
                                            }
                                            else if (ShouldUseMultilineField(field))
                                            {
                                                <textarea class="gnougo-composer__input gnougo-hitl-field__textarea @(LooksLikeCodeField(field) ? "gnougo-hitl-field__textarea--code" : "")"
                                                          value="@GetFieldValue(field.Name)"
                                                          @oninput="@(e => SetFieldValue(field.Name, e.Value?.ToString() ?? ""))"></textarea>
                                            }
                                            else
                                            {
                                                <input type="text"
                                                       class="gnougo-composer__input"
                                                       style="width: 100%; padding: 6px 10px; border-radius: 6px;"
                                                       value="@GetFieldValue(field.Name)"
                                                       @onchange="@(e => SetFieldValue(field.Name, e.Value?.ToString() ?? ""))" />
                                            }
                                        </div>
                                    }
                                    <button class="gnougo-composer__send"
                                            type="button"
                                            style="margin-top: 8px;"
                                            @onclick="SubmitHumanInputFields">
                                        Submit
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </article>
            }
        </section>

        <footer class="gnougo-chat__composer">
            <EditForm id="@ComposerDropZoneId" class="gnougo-composer" Model="_model" OnValidSubmit="SendAsync">
                <DataAnnotationsValidator />
                <input id="@ComposerFileInputId" class="gnougo-composer__file-input" type="file" multiple />

                @if (_composerUploads.Count > 0)
                {
                    <div class="gnougo-composer__uploads" aria-live="polite">
                        @foreach (var upload in _composerUploads)
                        {
                            <div class="gnougo-composer__upload @(upload.IsCompleted ? "gnougo-composer__upload--done" : upload.IsFailed ? "gnougo-composer__upload--failed" : "gnougo-composer__upload--loading")">
                                <div class="gnougo-composer__upload-icon">@(upload.IsCompleted ? "✓" : upload.IsFailed ? "!" : "⇧")</div>
                                <div class="gnougo-composer__upload-body">
                                    <div class="gnougo-composer__upload-title" title="@upload.FileName">@upload.FileName</div>
                                    <div class="gnougo-composer__upload-meta">
                                        @if (upload.IsCompleted)
                                        {
                                            <span>Uploaded · id @ShortId(upload.FileId)</span>
                                        }
                                        else if (upload.IsFailed)
                                        {
                                            <span>@upload.Error</span>
                                        }
                                        else
                                        {
                                            <span>@FormatBytes(upload.SizeBytes) · @upload.Progress%</span>
                                        }
                                    </div>
                                    <div class="gnougo-composer__upload-progress" aria-hidden="true">
                                        <div class="gnougo-composer__upload-progress-bar" style="width: @upload.Progress%"></div>
                                    </div>
                                </div>
                                <button class="gnougo-composer__upload-remove"
                                        type="button"
                                        title="Remove file from message"
                                        disabled="@_isStreaming"
                                        @onclick="@(() => RemoveComposerUpload(upload.ClientId))">
                                    ✕
                                </button>
                            </div>
                        }
                    </div>
                }

                @if (UseWorkflowInputComposer && _workflowInputSchema is not null)
                {
                    <div class="gnougo-composer__workflow" aria-label="Workflow inputs">
                        <div class="gnougo-composer__workflow-header">
                            <div>
                                <div class="gnougo-composer__workflow-title">Workflow inputs</div>
                                <div class="gnougo-composer__workflow-subtitle">
                                    @if (!string.IsNullOrWhiteSpace(_workflowInputSchema.AgentName))
                                    {
                                        <span>Agent: @_workflowInputSchema.AgentName</span>
                                    }
                                    else
                                    {
                                        <span>Dynamic workflow</span>
                                    }
                                </div>
                            </div>
                            @if (_workflowInputsLoading)
                            {
                                <span class="gnougo-composer__workflow-loading">Loading…</span>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_workflowInputSchema.ErrorMessage))
                        {
                            <div class="gnougo-composer__workflow-error">
                                Could not load workflow inputs: @_workflowInputSchema.ErrorMessage
                            </div>
                        }

                        <div class="gnougo-composer__workflow-grid">
                            @foreach (var field in _workflowInputSchema.Fields)
                            {
                                @RenderWorkflowInputField(field, field.Name, 0)
                            }
                        </div>
                    </div>

                    <div class="gnougo-composer__row gnougo-composer__row--actions">
                        <button class="gnougo-composer__attach"
                                type="button"
                                title="Attach documents"
                                disabled="@_isStreaming"
                                @onclick="OpenFilePickerAsync">
                            📎
                        </button>

                        <div class="gnougo-composer__workflow-action-spacer"></div>

                        @if (_isStreaming)
                        {
                            <button class="gnougo-composer__send gnougo-composer__send--stop" type="button" @onclick="Stop" title="Stop">
                                <span class="gnougo-composer__send-text">Stop</span>
                            </button>
                        }
                        else
                        {
                            <button class="gnougo-composer__send" type="submit" disabled="@(!CanSend)">
                                <span class="gnougo-composer__send-text">Run workflow</span>
                            </button>
                        }
                    </div>

                    <div class="gnougo-composer__hint">
                        Fill the selected agent inputs • JSON/YAML accepted for complex fields • Drag & drop documents to upload them first
                    </div>
                }
                else
                {
                    <div class="gnougo-composer__row">
                        <button class="gnougo-composer__attach"
                                type="button"
                                title="Attach documents"
                                disabled="@_isStreaming"
                                @onclick="OpenFilePickerAsync">
                            📎
                        </button>

                        <textarea class="gnougo-composer__input"
                                  @bind="_model.Prompt"
                                  @bind:event="oninput"
                                  placeholder="Write a message or YAML… Drop documents here to upload them before sending."

                                  rows="1"
                                  disabled="@(_isStreaming || HasBlockingUploads)"
                                  @onkeydown="OnKeyDown">
                        </textarea>

                        @if (_isStreaming)
                        {
                            <button class="gnougo-composer__send gnougo-composer__send--stop" type="button" @onclick="Stop" title="Stop">
                                <span class="gnougo-composer__send-text">Stop</span>
                            </button>
                        }
                        else
                        {
                            <button class="gnougo-composer__send" type="submit" disabled="@(!CanSend)">
                                <span class="gnougo-composer__send-text">Send</span>
                            </button>
                        }
                    </div>

                    <div class="gnougo-composer__hint">
                        Enter to send • Shift+Enter for newline • Drag & drop documents to upload them first
                    </div>
                }
            </EditForm>
        </footer>
    </main>

    <ChatTraceSidebar Message="_selectedTraceMessage"
                      IsOpen="_traceSidebarOpen"
                      OnClose="CloseTraceSidebarAsync" />
</div>

@code
{
    private sealed class ComposeModel
    {
        public string Prompt { get; set; } = "";
    }

    private sealed class ComposerUploadModel
    {
        public string ClientId { get; init; } = "";
        public string FileName { get; set; } = "";
        public long SizeBytes { get; set; }
        public int Progress { get; set; }
        public string? FileId { get; set; }
        public string? Error { get; set; }

        public bool IsCompleted => !string.IsNullOrWhiteSpace(FileId) && string.IsNullOrWhiteSpace(Error);
        public bool IsFailed => !string.IsNullOrWhiteSpace(Error);
    }

    private sealed class HumanInputModel
    {
        public string RunId { get; set; } = "";
        public string StepId { get; set; } = "";
        public string Prompt { get; set; } = "";
        public string? Context { get; set; }
        public List<string>? Choices { get; set; }
        public List<HumanInputFieldModel>? Fields { get; set; }
    }

    private sealed class HumanInputFieldModel
    {
        public string Name { get; set; } = "";
        public string Type { get; set; } = "string";
        public bool Required { get; set; }
        public string? Description { get; set; }
        public List<string>? Options { get; set; }
        public string? Default { get; set; }
    }

    private const string StorageKeyV2 = "gnougo-agent.gnougo-chat.store.v2";
    private const string LegacyStorageKey = "gnougo-gnougo-chat.gnougo-chat.history.v1";

    private static readonly JsonSerializerOptions PrettyJsonOptions = new() { WriteIndented = true };

    private readonly ComposeModel _model = new();
    private const string ComposerDropZoneId = "chatComposerDropZone";
    private const string ComposerFileInputId = "chatComposerFileInput";
    private DotNetObjectReference<ChatPage>? _fileUploadInterop;
    private readonly List<ComposerUploadModel> _composerUploads = new();
    private ChatStoreDto _store = new("", new List<ChatSessionDto>());
    private ChatSessionDto? _active;
    private string? _defaultAgentName;
    private WorkflowInputSchema? _workflowInputSchema;
    private readonly Dictionary<string, string> _workflowInputValues = new(StringComparer.Ordinal);
    private bool _workflowInputsLoading;
    private readonly List<string> _availableAgents = new();
    private bool _agentsLoading;

    private bool _sidebarOpen;
    private bool _isStreaming;
    private string _error = "";
    private bool _browserStatePending = true;

    private CancellationTokenSource? _cts;
    private bool _needsMarkdownEnhance;

    private HumanInputModel? _pendingHumanInput;
    private readonly Dictionary<string, string> _fieldValues = new();
    private bool _traceSidebarOpen;
    private ChatMessageDto? _selectedTraceMessage;
    private AppVersionDto? _appVersion;

    /// <summary>Accumulates all HITL prompt+response pairs so they can be grouped
    /// into a single message at the end of the flow.</summary>
    private readonly List<(string Question, string Answer)> _hitlLog = new();

    /// <summary>Typewriter delay in ms between characters.</summary>
    private const int TypewriterDelayMs = 12;

    private bool HasBlockingUploads => _composerUploads.Any(static upload => !upload.IsCompleted);

    private bool UseWorkflowInputComposer => _workflowInputSchema is { IsPromptOnly: false };

    private string DisplayVersion => _appVersion?.ShortVersion ?? VersionInfo.ShortVersion;

    private string DisplayVersionTitle => _appVersion?.Version ?? VersionInfo.Version;

    private bool CanSend => !_isStreaming
                            && !HasBlockingUploads
                            && (UseWorkflowInputComposer || !string.IsNullOrWhiteSpace(_model.Prompt));

    private IReadOnlyList<string> UploadedFileIds => _composerUploads
        .Where(static upload => upload.IsCompleted && !string.IsNullOrWhiteSpace(upload.FileId))
        .Select(static upload => upload.FileId!)
        .ToArray();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var snapshot = await UserConfigClient.GetAsync();
            _defaultAgentName = snapshot.DefaultAgent;
            await RefreshAvailableAgentsAsync();
            await RefreshWorkflowInputSchemaAsync();
            EnsureActiveSession();
            await RegisterFileUploadInteropAsync();
            await LoadAppVersionAsync();
            StateHasChanged();
        }

        if (_browserStatePending)
        {
            var initialized = await TryInitializeBrowserStateAsync();
            if (initialized)
            {
                _needsMarkdownEnhance = true;
                StateHasChanged();
                await ScrollToBottomAsync();
                return;
            }
        }

        if (_needsMarkdownEnhance && !_isStreaming)
        {
            _needsMarkdownEnhance = false;
            try
            {
                await Js.InvokeVoidAsync("GnOuGo.Agent.markdown.enhance", "chatMessages");
            }
            catch (JSDisconnectedException)
            {
            }
            catch (InvalidOperationException ex) when (IsDeferredJavaScriptInterop(ex))
            {
            }
        }
    }

    private async Task LoadAppVersionAsync()
    {
        try
        {
            var http = HttpClientFactory.CreateClient();
            var versionUri = Navigation.ToAbsoluteUri("api/version");
            _appVersion = await http.GetFromJsonAsync(versionUri, ChatJsonContext.Default.AppVersionDto);
        }
        catch (HttpRequestException)
        {
        }
        catch (JsonException)
        {
        }
        catch (InvalidOperationException)
        {
        }
    }

    private static string FormatHumanInputContextAsMarkdown(string? context)
    {
        if (string.IsNullOrWhiteSpace(context))
            return string.Empty;

        var normalized = NormalizeLineEndings(context).Trim();

        if (TryExtractSingleCodeFence(normalized, out var language, out var fencedContent))
        {
            var content = NormalizeLineEndings(fencedContent).Trim();
            if (IsJsonLanguage(language) && TryFormatJson(content, out var prettyJson))
                return BuildFencedCode("json", prettyJson);
            if (IsYamlLanguage(language) || LooksLikeYaml(content))
                return BuildFencedCode(string.IsNullOrWhiteSpace(language) ? "yaml" : language, content);
            return BuildFencedCode(language, content);
        }

        if (TryFormatJson(normalized, out var formattedJson))
            return BuildFencedCode("json", formattedJson);

        if (LooksLikeYaml(normalized))
            return BuildFencedCode("yaml", normalized);

        return normalized;
    }

    private static string FormatEditableFieldValue(HumanInputFieldModel field, string value)
    {
        var normalized = NormalizeLineEndings(value).Trim();
        if ((IsJsonField(field) || LooksLikeJson(normalized)) && TryFormatJson(normalized, out var formattedJson))
            return formattedJson;

        return NormalizeLineEndings(value);
    }

    private static bool ShouldUseMultilineField(HumanInputFieldModel field)
    {
        var type = field.Type.Trim();
        return type.Equals("text", StringComparison.OrdinalIgnoreCase)
               || type.Equals("textarea", StringComparison.OrdinalIgnoreCase)
               || type.Equals("yaml", StringComparison.OrdinalIgnoreCase)
               || type.Equals("json", StringComparison.OrdinalIgnoreCase)
               || LooksLikeCodeField(field)
               || (field.Default?.Contains('\n') ?? false);
    }

    private static bool LooksLikeCodeField(HumanInputFieldModel field)
        => IsYamlField(field) || IsJsonField(field);

    private static bool IsYamlField(HumanInputFieldModel field)
        => field.Type.Equals("yaml", StringComparison.OrdinalIgnoreCase)
           || field.Name.Contains("yaml", StringComparison.OrdinalIgnoreCase)
           || field.Name.Contains("workflow", StringComparison.OrdinalIgnoreCase)
           || (field.Description?.Contains("YAML", StringComparison.OrdinalIgnoreCase) ?? false);

    private static bool IsJsonField(HumanInputFieldModel field)
        => field.Type.Equals("json", StringComparison.OrdinalIgnoreCase)
           || field.Name.Contains("json", StringComparison.OrdinalIgnoreCase)
           || (field.Description?.Contains("JSON", StringComparison.OrdinalIgnoreCase) ?? false);

    private static bool TryFormatJson(string input, out string prettyJson)
    {
        prettyJson = string.Empty;
        if (!LooksLikeJson(input))
            return false;

        try
        {
            using var document = JsonDocument.Parse(input);
            prettyJson = JsonSerializer.Serialize(document.RootElement, PrettyJsonOptions);
            return true;
        }
        catch (JsonException)
        {
            return false;
        }
    }

    private static bool LooksLikeJson(string value)
    {
        var trimmed = value.TrimStart();
        return trimmed.StartsWith('{') || trimmed.StartsWith('[');
    }

    private static bool LooksLikeYaml(string value)
    {
        if (value.StartsWith("version:", StringComparison.OrdinalIgnoreCase)
            || value.StartsWith("dsl:", StringComparison.OrdinalIgnoreCase)
            || value.StartsWith("---", StringComparison.Ordinal))
        {
            return true;
        }

        var lines = value.Split('\n', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
        if (lines.Length < 2)
            return false;

        var yamlLikeLines = 0;
        foreach (var line in lines)
        {
            if (line.StartsWith('#') || line.StartsWith("- ", StringComparison.Ordinal))
            {
                yamlLikeLines++;
                continue;
            }

            var index = line.IndexOf(':', StringComparison.Ordinal);
            if (index <= 0)
                continue;

            var key = line[..index].Trim();
            if (key.Length == 0 || key.Contains('{') || key.Contains('['))
                continue;

            yamlLikeLines++;
            if (yamlLikeLines >= 2)
                return true;
        }

        return false;
    }

    private static bool TryExtractSingleCodeFence(string markdown, out string language, out string content)
    {
        language = string.Empty;
        content = string.Empty;

        var lines = markdown.Split('\n');
        if (lines.Length < 2 || !lines[0].TrimStart().StartsWith("```", StringComparison.Ordinal))
            return false;

        var firstLine = lines[0].Trim();
        if (!lines[^1].Trim().StartsWith("```", StringComparison.Ordinal))
            return false;

        language = firstLine.Length > 3 ? firstLine[3..].Trim() : string.Empty;
        content = string.Join("\n", lines.Skip(1).Take(lines.Length - 2));
        return true;
    }

    private static bool IsJsonLanguage(string language)
        => language.Equals("json", StringComparison.OrdinalIgnoreCase)
           || language.Equals("jsonc", StringComparison.OrdinalIgnoreCase);

    private static bool IsYamlLanguage(string language)
        => language.Equals("yaml", StringComparison.OrdinalIgnoreCase)
           || language.Equals("yml", StringComparison.OrdinalIgnoreCase);

    private static string BuildFencedCode(string language, string content)
    {
        var fence = content.Contains("```", StringComparison.Ordinal) ? "````" : "```";
        return $"{fence}{language}\n{content}\n{fence}";
    }

    private static string NormalizeLineEndings(string value)
        => value.Replace("\r\n", "\n", StringComparison.Ordinal).Replace('\r', '\n');


    private void ToggleSidebar() => _sidebarOpen = !_sidebarOpen;
    private void CloseSidebar() => _sidebarOpen = false;

    private async Task RefreshWorkflowInputSchemaAsync()
    {
        _workflowInputsLoading = true;

        try
        {
            _workflowInputSchema = await SmartFlow.GetActiveWorkflowInputSchemaAsync(_defaultAgentName, CancellationToken.None);
            ResetWorkflowInputValues();
        }
        catch (Exception ex)
        {
            _workflowInputSchema = new WorkflowInputSchema(_defaultAgentName, Array.Empty<WorkflowInputFieldSchema>(), ex.Message);
            _workflowInputValues.Clear();
        }
        finally
        {
            _workflowInputsLoading = false;
        }
    }

    private async Task RefreshAvailableAgentsAsync()
    {
        _agentsLoading = true;
        try
        {
            var names = await SmartFlow.ListAgentNamesAsync(CancellationToken.None);
            _availableAgents.Clear();
            _availableAgents.AddRange(names);

            if (!string.IsNullOrWhiteSpace(_defaultAgentName)
                && !_availableAgents.Contains(_defaultAgentName, StringComparer.OrdinalIgnoreCase))
            {
                _availableAgents.Insert(0, _defaultAgentName);
            }
        }
        finally
        {
            _agentsLoading = false;
        }
    }

    private async Task OnAgentSelectionChangedAsync(ChangeEventArgs e)
    {
        if (_isStreaming)
            return;

        var selectedAgent = e.Value?.ToString()?.Trim();
        if (string.IsNullOrWhiteSpace(selectedAgent))
            return;

        if (string.Equals(_defaultAgentName, selectedAgent, StringComparison.Ordinal))
            return;

        var snapshot = await UserConfigClient.SetAsync(defaultAgent: selectedAgent, ct: CancellationToken.None);
        _defaultAgentName = snapshot?.DefaultAgent ?? selectedAgent;

        SyncSessionsToDefaultAgent();
        await RefreshWorkflowInputSchemaAsync();
        await PersistAsync();
        StateHasChanged();
    }

    private void ResetWorkflowInputValues()
    {
        _workflowInputValues.Clear();
        if (_workflowInputSchema is null)
            return;

        foreach (var field in _workflowInputSchema.Fields)
            SeedWorkflowInputValue(field, field.Name, field.DefaultValue);
    }

    private void SeedWorkflowInputValue(WorkflowInputFieldSchema field, string path, JsonNode? defaultValue)
    {
        if (IsStructuredObjectField(field))
        {
            var defaultObject = defaultValue as JsonObject;
            foreach (var property in field.PropertyList)
            {
                JsonNode? propertyDefault = null;
                defaultObject?.TryGetPropertyValue(property.Name, out propertyDefault);
                SeedWorkflowInputValue(property, $"{path}.{property.Name}", propertyDefault ?? property.DefaultValue);
            }

            return;
        }

        var value = WorkflowInputComposer.FormatNodeForEditor(defaultValue ?? field.DefaultValue, field.Type);
        if (!string.IsNullOrEmpty(value))
            _workflowInputValues[path] = value;
    }

    private static bool IsStructuredObjectField(WorkflowInputFieldSchema field)
        => string.Equals(field.Type, "object", StringComparison.OrdinalIgnoreCase)
           && field.PropertyList.Count > 0;

    private RenderFragment RenderWorkflowInputField(WorkflowInputFieldSchema field, string path, int depth) => @<div class="gnougo-workflow-input @(depth > 0 ? "gnougo-workflow-input--nested" : "")">
        <label class="gnougo-workflow-input__label" for="@WorkflowInputDomId(path)">
            <span>@field.Name</span>
            @if (field.Required)
            {
                <span class="gnougo-workflow-input__required">*</span>
            }
            <span class="gnougo-workflow-input__type">@field.Type</span>
        </label>

        @if (!string.IsNullOrWhiteSpace(field.Description))
        {
            <div class="gnougo-workflow-input__description">@field.Description</div>
        }

        @if (IsStructuredObjectField(field))
        {
            <div class="gnougo-workflow-input__object">
                @foreach (var property in field.PropertyList)
                {
                    @RenderWorkflowInputField(property, $"{path}.{property.Name}", depth + 1)
                }
            </div>
        }
        else if (WorkflowInputComposer.IsBooleanType(field.Type))
        {
            <select id="@WorkflowInputDomId(path)"
                    class="gnougo-composer__input gnougo-workflow-input__control"
                    disabled="@(_isStreaming || HasBlockingUploads)"
                    value="@GetWorkflowInputValue(path)"
                    @onchange="@(e => SetWorkflowInputValue(path, e.Value?.ToString() ?? ""))">
                <option value="">Select…</option>
                <option value="true">true</option>
                <option value="false">false</option>
            </select>
        }
        else if (ShouldUseWorkflowMultilineField(field))
        {
            <textarea id="@WorkflowInputDomId(path)"
                      class="gnougo-composer__input gnougo-workflow-input__control gnougo-workflow-input__textarea @(WorkflowInputComposer.IsComplexType(field.Type) ? "gnougo-workflow-input__textarea--code" : "")"
                      rows="@(WorkflowInputComposer.IsComplexType(field.Type) ? 5 : 2)"
                      disabled="@(_isStreaming || HasBlockingUploads)"
                      value="@GetWorkflowInputValue(path)"
                      @oninput="@(e => SetWorkflowInputValue(path, e.Value?.ToString() ?? ""))"></textarea>
        }
        else
        {
            <input id="@WorkflowInputDomId(path)"
                   type="@(WorkflowInputComposer.IsNumberType(field.Type) ? "number" : "text")"
                   class="gnougo-composer__input gnougo-workflow-input__control"
                   disabled="@(_isStreaming || HasBlockingUploads)"
                   value="@GetWorkflowInputValue(path)"
                   @oninput="@(e => SetWorkflowInputValue(path, e.Value?.ToString() ?? ""))" />
        }
    </div>;

    private static bool ShouldUseWorkflowMultilineField(WorkflowInputFieldSchema field)
        => WorkflowInputComposer.IsComplexType(field.Type)
           || field.Type.Equals("text", StringComparison.OrdinalIgnoreCase)
           || (field.DefaultValue is JsonValue value
               && value.TryGetValue(out string? text)
               && text?.Contains('\n') == true);

    private string GetWorkflowInputValue(string path)
        => _workflowInputValues.TryGetValue(path, out var value) ? value : string.Empty;

    private void SetWorkflowInputValue(string path, string value)
        => _workflowInputValues[path] = value;

    private static string WorkflowInputDomId(string path)
        => "workflowInput_" + string.Concat(path.Select(ch => char.IsLetterOrDigit(ch) ? ch : '_'));

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (_isStreaming || HasBlockingUploads) return;
        if (e.Key is "Enter" && !e.ShiftKey)
        {
            if (CanSend)
                await SendAsync();
        }
    }

    /// <summary>
    /// Typewriter effect: appends text character by character with a small delay.
    /// </summary>
    private async Task TypewriterAppendAsync(string text, ChatMessageDto targetMsg, CancellationToken ct)
    {
        foreach (var ch in text)
        {
            ct.ThrowIfCancellationRequested();

            targetMsg = targetMsg with { Content = targetMsg.Content + ch };
            ReplaceLastAssistant(targetMsg);
            TouchActive();
            StateHasChanged();

            // Only delay every few characters for performance
            if (ch is ' ' or '\n' or '.' or ',' or '!' or '?')
            {
                await Task.Delay(TypewriterDelayMs, ct);
                await ScrollToBottomAsync();
            }
        }
    }

    private async Task<bool> TryInitializeBrowserStateAsync()
    {
        try
        {
            await LoadStoreAsync();
            var sessionsChanged = SyncSessionsToDefaultAgent();
            EnsureActiveSession();
            if (sessionsChanged)
                await PersistAsync();
            _browserStatePending = false;
            return true;
        }
        catch (JSDisconnectedException)
        {
            return false;
        }
        catch (InvalidOperationException ex) when (IsDeferredJavaScriptInterop(ex))
        {
            return false;
        }
    }

    private static bool IsDeferredJavaScriptInterop(InvalidOperationException ex)
        => ex.Message.Contains("prerender", StringComparison.OrdinalIgnoreCase)
           || ex.Message.Contains("statically rendered", StringComparison.OrdinalIgnoreCase)
           || ex.Message.Contains("JavaScript interop", StringComparison.OrdinalIgnoreCase);

