        return type.Equals("text", StringComparison.OrdinalIgnoreCase)
               || type.Equals("textarea", StringComparison.OrdinalIgnoreCase)
               || type.Equals("markdown", StringComparison.OrdinalIgnoreCase)
               || type.Equals("yaml", StringComparison.OrdinalIgnoreCase)
               || type.Equals("json", StringComparison.OrdinalIgnoreCase)
               || LooksLikeCodeField(field)
               || (field.Default?.Contains('\n') ?? false);
    }

    private static string GetFieldInputType(HumanInputFieldModel field)
    {
        var type = field.Type.Trim();
        if (type.Equals("number", StringComparison.OrdinalIgnoreCase)
            || type.Equals("integer", StringComparison.OrdinalIgnoreCase))
            return "number";
        if (type.Equals("date", StringComparison.OrdinalIgnoreCase))
            return "date";
        if (type.Equals("password", StringComparison.OrdinalIgnoreCase)
            || type.Equals("secret", StringComparison.OrdinalIgnoreCase))
            return "password";
        if (type.Equals("email", StringComparison.OrdinalIgnoreCase))
            return "email";
        if (type.Equals("url", StringComparison.OrdinalIgnoreCase))
            return "url";
        return "text";
    }

