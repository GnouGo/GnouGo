            foreach (var execution in _executions.Values)
            {
                await Js.InvokeVoidAsync(
                    "GnOuGo.Agent.workflowAnimation.dispose",
                    execution.HostId);
            }
        }
        catch (JSDisconnectedException)
        {
        }
        catch (InvalidOperationException)
        {
        }

        _fileUploadInterop?.Dispose();
    }

