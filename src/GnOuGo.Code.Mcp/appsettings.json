{
  "Code": {
    "DefaultWorkingDirectory": "GnOuGo",
    "MaxFileSizeBytes": 524288,
    "MaxSearchResults": 100,
    "MaxPromptCharacters": 24000,
    "AllowWrites": false,
    "AllowedWorkingRoots": [],
    "AllowedExtensions": [
      ".cs",
      ".csproj",
      ".sln",
      ".json",
      ".xml",
      ".yaml",
      ".yml",
      ".md",
      ".txt",
      ".ps1",
      ".sh",
      ".js",
      ".jsx",
      ".ts",
      ".tsx",
      ".py",
      ".css",
      ".html"
    ],
    "Copilot": {
      "Provider": "Copilot",
      "Model": "gpt-4.1",
      "Mode": "plan",
      "ReasoningEffort": "high",
      "Endpoint": "https://models.github.ai/inference",
      "ApiKey": "",
      "UseLoggedInUser": false,
      "ForwardTraceContext": true,
      "LogLevel": "warn",
      "RequestTimeoutSeconds": 120,
      "Telemetry": {
        "Enabled": true,
        "ExporterType": "otlp",
        "OtlpEndpoint": "http://127.0.0.1:4317",
        "FilePath": null,
        "SourceName": "GnOuGo.Code.Mcp.Copilot",
        "CaptureContent": false
      },
      "TokenEnvironmentVariables": [
        "GITHUB_TOKEN",
        "COPILOT_API_KEY"
      ]
    },
    "Git": {
      "AllowMutations": false,
      "AllowNetworkOperations": false,
      "RequireCleanWorkingTreeForMerge": true,
      "MaxDiffCharacters": 120000,
      "MaxLogCount": 100,
      "DefaultAuthorName": "GnOuGo Agent",
      "DefaultAuthorEmail": "gnougo-agent@localhost",
      "DefaultRemoteName": "origin",
      "Username": "x-access-token",
      "Token": "",
      "TokenEnvironmentVariables": [
        "GITHUB_TOKEN",
        "COPILOT_API_KEY"
      ]
    }
  }
}



