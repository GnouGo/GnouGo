<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- Trimming-friendly defaults (activated on publish when PublishTrimmed=true) -->
    <TrimMode>full</TrimMode>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>

    <!-- Keep the app small and trimming-friendly -->
    <InvariantGlobalization>false</InvariantGlobalization>
    <ServerGarbageCollection>true</ServerGarbageCollection>
    <RootNamespace>GnOuGo.OtlpCollector</RootNamespace>

    <!-- ═══════════════════════════════════════════════════════════════════
         OpenTelemetry Proto — change this single value to bump the version.
         The EnsureOtlpProtos target below downloads the files automatically.
         ═══════════════════════════════════════════════════════════════════ -->
    <OtlpProtoVersion>v1.4.0</OtlpProtoVersion>
    <OtlpProtoDir>$(MSBuildProjectDirectory)/Protos/otlp-proto</OtlpProtoDir>
    <OtlpProtoVersionFile>$(OtlpProtoDir)/VERSION</OtlpProtoVersionFile>
    <OtlpProtoBaseUrl>https://raw.githubusercontent.com/open-telemetry/opentelemetry-proto/$(OtlpProtoVersion)</OtlpProtoBaseUrl>
  </PropertyGroup>

  <!-- ═══════════════════════════════════════════════════════════════════════
       Auto-download official OpenTelemetry .proto files before build.
       Cross-platform (Windows / Linux / macOS) — uses only MSBuild tasks.
       Idempotent: skips if VERSION file already matches OtlpProtoVersion.
       ═══════════════════════════════════════════════════════════════════════ -->
  <Target Name="EnsureOtlpProtos" BeforeTargets="PrepareForBuild">
    <ItemGroup>
      <_RequiredOtlpProto Include="opentelemetry/proto/common/v1/common.proto" />
      <_RequiredOtlpProto Include="opentelemetry/proto/resource/v1/resource.proto" />
      <_RequiredOtlpProto Include="opentelemetry/proto/trace/v1/trace.proto" />
      <_RequiredOtlpProto Include="opentelemetry/proto/logs/v1/logs.proto" />
      <_RequiredOtlpProto Include="opentelemetry/proto/metrics/v1/metrics.proto" />
      <_RequiredOtlpProto Include="opentelemetry/proto/collector/trace/v1/trace_service.proto" />
      <_RequiredOtlpProto Include="opentelemetry/proto/collector/logs/v1/logs_service.proto" />
      <_RequiredOtlpProto Include="opentelemetry/proto/collector/metrics/v1/metrics_service.proto" />
      <_MissingOtlpProto Include="@(_RequiredOtlpProto)" Condition="!Exists('$(OtlpProtoDir)/%(Identity)')" />
    </ItemGroup>

    <!-- Read current version if file exists -->
    <ReadLinesFromFile File="$(OtlpProtoVersionFile)" Condition="Exists('$(OtlpProtoVersionFile)')">
      <Output TaskParameter="Lines" ItemName="_CurrentProtoVersion" />
    </ReadLinesFromFile>

    <!-- Skip download only if version matches and all required files are present -->
    <PropertyGroup>
      <_ProtoUpToDate Condition="'@(_CurrentProtoVersion)' == '$(OtlpProtoVersion)' and '@(_MissingOtlpProto)' == ''">true</_ProtoUpToDate>
    </PropertyGroup>
    <Message Importance="normal" Text="OpenTelemetry Proto $(OtlpProtoVersion) already present — skipping download." Condition="'$(_ProtoUpToDate)' == 'true'" />
    <Message Importance="high" Text="OpenTelemetry Proto $(OtlpProtoVersion) will be refreshed because required files are missing: @(_MissingOtlpProto, ', ')" Condition="'$(_ProtoUpToDate)' != 'true' and '@(_MissingOtlpProto)' != ''" />

    <!-- Download each proto file if not up to date -->
    <ItemGroup Condition="'$(_ProtoUpToDate)' != 'true'">
      <_OtlpProtoFile Include="@(_RequiredOtlpProto)" />
    </ItemGroup>

    <Message Importance="high" Text="Downloading OpenTelemetry Proto $(OtlpProtoVersion) ..." Condition="'$(_ProtoUpToDate)' != 'true'" />

    <MakeDir Directories="$(OtlpProtoDir)/$([System.IO.Path]::GetDirectoryName('%(_OtlpProtoFile.Identity)').Replace('\', '/'))" Condition="'$(_ProtoUpToDate)' != 'true'" />

    <DownloadFile SourceUrl="$(OtlpProtoBaseUrl)/%(_OtlpProtoFile.Identity)" DestinationFolder="$(OtlpProtoDir)/$([System.IO.Path]::GetDirectoryName('%(_OtlpProtoFile.Identity)').Replace('\', '/'))" DestinationFileName="$([System.IO.Path]::GetFileName('%(_OtlpProtoFile.Identity)'))" SkipUnchangedFiles="false" Condition="'$(_ProtoUpToDate)' != 'true'" />

    <WriteLinesToFile File="$(OtlpProtoVersionFile)" Lines="$(OtlpProtoVersion)" Overwrite="true" Condition="'$(_ProtoUpToDate)' != 'true'" />

    <Message Importance="high" Text="OpenTelemetry Proto $(OtlpProtoVersion) ready." Condition="'$(_ProtoUpToDate)' != 'true'" />
  </Target>

  <Target Name="RemoveStaleMessageOnlyGrpcGeneratedFiles" BeforeTargets="CoreCompile">
    <ItemGroup>
      <_StaleMessageOnlyGrpcGeneratedFile Include="$(IntermediateOutputPath)opentelemetry/proto/common/v1/CommonGrpc.cs" />
      <_StaleMessageOnlyGrpcGeneratedFile Include="$(IntermediateOutputPath)opentelemetry/proto/resource/v1/ResourceGrpc.cs" />
      <_StaleMessageOnlyGrpcGeneratedFile Include="$(IntermediateOutputPath)opentelemetry/proto/trace/v1/TraceGrpc.cs" />
      <_StaleMessageOnlyGrpcGeneratedFile Include="$(IntermediateOutputPath)opentelemetry/proto/logs/v1/LogsGrpc.cs" />
      <_StaleMessageOnlyGrpcGeneratedFile Include="$(IntermediateOutputPath)opentelemetry/proto/metrics/v1/MetricsGrpc.cs" />
    </ItemGroup>
    <Delete Files="@(_StaleMessageOnlyGrpcGeneratedFile)" />
  </Target>

  <ItemGroup>
    <!--
      Official OpenTelemetry Proto files — auto-downloaded by EnsureOtlpProtos target.
      Change OtlpProtoVersion above to bump. Manual: Protos/download-protos.ps1 -Force
      Message-only protos must use GrpcServices="None". Only collector service
      protos generate gRPC server stubs; otherwise stale *Grpc.cs files can
      duplicate all message types during incremental builds.
    -->
    <Protobuf Include="Protos/otlp-proto/opentelemetry/proto/common/v1/common.proto" ProtoRoot="Protos/otlp-proto" GrpcServices="None" />
    <Protobuf Include="Protos/otlp-proto/opentelemetry/proto/resource/v1/resource.proto" ProtoRoot="Protos/otlp-proto" GrpcServices="None" />
    <Protobuf Include="Protos/otlp-proto/opentelemetry/proto/trace/v1/trace.proto" ProtoRoot="Protos/otlp-proto" GrpcServices="None" />
    <Protobuf Include="Protos/otlp-proto/opentelemetry/proto/logs/v1/logs.proto" ProtoRoot="Protos/otlp-proto" GrpcServices="None" />
    <Protobuf Include="Protos/otlp-proto/opentelemetry/proto/metrics/v1/metrics.proto" ProtoRoot="Protos/otlp-proto" GrpcServices="None" />
    <Protobuf Include="Protos/otlp-proto/opentelemetry/proto/collector/trace/v1/trace_service.proto" ProtoRoot="Protos/otlp-proto" GrpcServices="Server" />
    <Protobuf Include="Protos/otlp-proto/opentelemetry/proto/collector/logs/v1/logs_service.proto" ProtoRoot="Protos/otlp-proto" GrpcServices="Server" />
    <Protobuf Include="Protos/otlp-proto/opentelemetry/proto/collector/metrics/v1/metrics_service.proto" ProtoRoot="Protos/otlp-proto" GrpcServices="Server" />
    <PackageReference Include="Grpc.Tools" Version="2.80.0">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Google.Protobuf" Version="3.35.0" />

    <!-- gRPC server -->
    <PackageReference Include="Grpc.AspNetCore" Version="2.80.0" />

    <!-- SQLite with Entity Framework Core -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="10.0.8" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="10.0.8">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\GnOuGo.AI.Core\GnOuGo.AI.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Update="appsettings*.json" CopyToPublishDirectory="Never" />
    <Content Update="ClientApp\package.json;ClientApp\tsconfig.json;ClientApp\tsconfig.*.json;ClientApp\vite.config.*" CopyToPublishDirectory="Never" />
    <None Update="ClientApp\package.json;ClientApp\tsconfig.json;ClientApp\tsconfig.*.json;ClientApp\vite.config.*" CopyToPublishDirectory="Never" />
  </ItemGroup>
  

  <!-- ============================================ -->
  <!-- Frontend Build Automation                    -->
  <!-- ============================================ -->
  
  <PropertyGroup>
    <ClientAppDir>$(MSBuildProjectDirectory)/ClientApp</ClientAppDir>
    <PnpmCommand Condition="'$(OS)' == 'Windows_NT'">corepack.cmd pnpm</PnpmCommand>
    <PnpmCommand Condition="'$(OS)' != 'Windows_NT'">corepack pnpm</PnpmCommand>
  </PropertyGroup>

  <!-- Target: Installer les dépendances pnpm si node_modules n'existe pas -->
  <Target Name="EnsureNodeModules" BeforeTargets="Build" Condition="'$(SkipClientBuild)' != 'true'">
    <Message Text="🔍 Vérification des dépendances pnpm..." Importance="high" />
    <Exec Command="$(PnpmCommand) --dir &quot;$(ClientAppDir)&quot; install --frozen-lockfile" Condition="!Exists('$(ClientAppDir)/node_modules')" />
  </Target>

  <!-- Target: Build le frontend React et copie vers wwwroot -->
  <Target Name="BuildClientApp" AfterTargets="EnsureNodeModules" BeforeTargets="Build" Condition="'$(SkipClientBuild)' != 'true'">
    <Message Text="🔨 Construction du frontend React..." Importance="high" />
    <Exec Command="$(PnpmCommand) --dir &quot;$(ClientAppDir)&quot; build" />
    <Message Text="✅ Frontend construit et copié vers wwwroot/" Importance="high" />
  </Target>

  <!-- Target: Nettoyer le build du frontend lors du Clean -->
  <Target Name="CleanClientApp" AfterTargets="Clean">
    <Message Text="🧹 Nettoyage du build frontend..." Importance="high" />
    <RemoveDir Directories="$(ClientAppDir)/dist" />
    <RemoveDir Directories="$(MSBuildProjectDirectory)/wwwroot/assets" />
  </Target>

</Project>
