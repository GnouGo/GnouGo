{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "OtlpTenantCollector": "Information"
    }
  },
  "Admin": {
    "Key": "dev-admin-change-me"
  },
  "Database": {
    "Path": "data/telemetry.db"
  },
  "Ingest": {
    "BatchSize": 100,
    "FlushSeconds": 1,
    "ChannelCapacity": 20000
  },
  "Retention": {
    "SweepSeconds": 60
  },
  "DevMode": {
    "Enabled": true
  },
  "Kestrel": {
    "Endpoints": {
      "Grpc": {
        "Url": "http://0.0.0.0:4317",
        "Protocols": "Http2"
      },
      "Http": {
        "Url": "http://0.0.0.0:4318",
        "Protocols": "Http1AndHttp2"
      }
    }
  }
}
