{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "OtlpTenantCollector": "Information"
    }
  },
  "Admin": {
    "Key": "dev-admin-change-me"
  },
  "Database": {
    "Path": "data/telemetry.db"
  },
  "Ingest": {
    "BatchSize": 100,
    "FlushSeconds": 1,
    "ChannelCapacity": 20000
  },
  "Retention": {
    "SweepSeconds": 60
  },
  "TelemetryRouting": {
    "Enabled": false,
    "TraceBufferSeconds": 2,
    "DefaultCollector": "B",
    "Collectors": {
      "A": {
        "Enabled": true,
        "Endpoint": "http://collector-a:4318",
        "IncludeTenantHeader": true,
        "TimeoutSeconds": 10
      },
      "B": {
        "Enabled": true,
        "Endpoint": "http://collector-b:4318",
        "IncludeTenantHeader": true,
        "TimeoutSeconds": 10
      },
      "C": {
        "Enabled": true,
        "Endpoint": "http://collector-c:4318",
        "IncludeTenantHeader": true,
        "TimeoutSeconds": 10
      }
    },
    "Rules": [
      {
        "Name": "name-or-value-filter-to-c",
        "Enabled": false,
        "Collector": "C",
        "Signals": [ "traces", "logs" ],
        "MatchAny": [
          {
            "SpanNameContains": [ "important-operation" ]
          },
          {
            "ServiceNameContains": [ "important-service" ]
          },
          {
            "AnyAttributes": [
              {
                "Key": "workflow.name",
                "Contains": "important-workflow"
              }
            ]
          }
        ]
      },
      {
        "Name": "rag-genai-workflows-to-a",
        "Enabled": true,
        "Collector": "A",
        "Signals": [ "traces", "logs" ],
        "MatchAny": [
          {
            "AnyAttributes": [
              {
                "Key": "workflow.type",
                "Value": "rag"
              }
            ]
          },
          {
            "AnyAttributes": [
              {
                "Key": "workflow.kind",
                "Value": "rag"
              }
            ]
          },
          {
            "AnyAttributes": [
              {
                "Key": "gen_ai.operation.name",
                "Contains": "rag"
              }
            ]
          },
          {
            "SpanNameContains": [ "rag", "retrieval", "embedding", "vector" ]
          }
        ]
      }
    ]
  },
  "DevMode": {
    "Enabled": true
  },
  "Kestrel": {
    "Endpoints": {
      "Grpc": {
        "Url": "http://0.0.0.0:4317",
        "Protocols": "Http2"
      },
      "Http": {
        "Url": "http://0.0.0.0:4318",
        "Protocols": "Http1AndHttp2"
      }
    }
  }
}
