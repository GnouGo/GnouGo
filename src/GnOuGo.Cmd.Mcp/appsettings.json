{
  "Cmd": {
    "DefaultTimeoutMs": 10000,
    "MaxTimeoutMs": 30000,
    "MaxOutputCharacters": 12000,
    "AllowedShells": [
      "powershell",
      "sh"
    ],
    "AllowedWorkingRoots": [
      "C:/github/GnOuGo.Agent"
    ],
    "EnvironmentAllowList": [
      "PATH",
      "PATHEXT",
      "ComSpec",
      "SystemRoot",
      "WINDIR",
      "TMP",
      "TEMP",
      "USERPROFILE",
      "HOME"
    ],
    "AllowedCommands": {
      "print_working_directory": {
        "Description": "Print the current working directory using the configured shell.",
        "Shell": "powershell",
        "Script": "Get-Location | Select-Object -ExpandProperty Path",
        "WorkingDirectory": "./GnOuGo.Agent"
      },
      "list_src": {
        "Description": "List top-level entries in the src folder.",
        "Shell": "powershell",
        "Script": "Get-ChildItem -Name",
        "WorkingDirectory": "./GnOuGo.Agent/src"
      },
      "git_status": {
        "Description": "Show a concise git working tree status for the repository.",
        "Shell": "powershell",
        "Script": "git --no-pager status --short --untracked-files=no",
        "WorkingDirectory": "./GnOuGo.Agent",
        "TimeoutMs": 30000
      },
      "dotnet_info": {
        "Description": "Display the local .NET SDK/runtime information.",
        "Shell": "powershell",
        "Script": "dotnet --info",
        "WorkingDirectory": "./GnOuGo.Agent"
      },
      "list_relative_path": {
        "Description": "List the contents of a relative path located inside the allowed repository root.",
        "Shell": "powershell",
        "Script": "Get-ChildItem -Name {{path}}",
        "WorkingDirectory": "./GnOuGo.Agent",
        "Parameters": {
          "path": {
            "Description": "Relative path to inspect inside the repository.",
            "Required": true,
            "Pattern": "^[A-Za-z0-9_./\\\\-]{1,120}$",
            "MaxLength": 120
          }
        }
      },
      "print_working_directory_sh": {
        "Description": "Print the current working directory using /bin/sh if available on the machine.",
        "Shell": "sh",
        "Script": "pwd",
        "WorkingDirectory": "./GnOuGo.Agent"
      }
    }
  }
}


