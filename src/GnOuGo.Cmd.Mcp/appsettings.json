{
  "Cmd": {
    "DefaultWorkingDirectory": "GnOuGo",
    "DefaultTimeoutMs": 60000,
    "MaxTimeoutMs": 300000,
    "MaxOutputCharacters": 128000,
    "AllowedShells": [
      "sh",
      "bash",
      "zsh",
      "powershell",
      "cmd"
    ],
    "AllowedWorkingRoots": [],
    "EnvironmentAllowList": [
      "PATH",
      "PATHEXT",
      "ComSpec",
      "SystemRoot",
      "WINDIR",
      "TMP",
      "TEMP",
      "USERPROFILE",
      "HOME"
    ],
    "AllowedCommands": {

      "print_working_directory": {
        "Description": "Print the current working directory of the default writable workspace.",
        "Shell": "sh",
        "Script": "pwd",
        "OsOverrides": {
          "windows": {
            "Shell": "powershell",
            "Script": "Get-Location | Select-Object -ExpandProperty Path"
          }
        }
      },

      "list_root": {
        "Description": "List top-level entries in the default writable workspace.",
        "Shell": "sh",
        "Script": "ls -1",
        "OsOverrides": {
          "windows": {
            "Shell": "powershell",
            "Script": "Get-ChildItem -Name ."
          }
        }
      },


      "list_relative_path": {
        "Description": "List the contents of a relative path located inside the default writable workspace.",
        "Shell": "sh",
        "Script": "ls -1 {{path}}",
        "Parameters": {
          "path": {
            "Description": "Relative path to inspect inside the writable workspace.",
            "Required": true,
            "Pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_./\\-]{1,240}$",
            "MaxLength": 240
          }
        },
        "OsOverrides": {
          "windows": {
            "Shell": "powershell",
            "Script": "Get-ChildItem -Name {{path}}"
          }
        }
      },

      "create_directory": {
        "Description": "Create a subdirectory inside the default writable workspace and return its resolved path.",
        "Shell": "sh",
        "Script": "mkdir -p {{path}} && cd {{path}} && pwd",
        "Parameters": {
          "path": {
            "Description": "Relative directory path to create inside the writable workspace.",
            "Required": true,
            "Pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_./\\-]{1,240}$",
            "MaxLength": 240
          }
        },
        "OsOverrides": {
          "windows": {
            "Shell": "powershell",
            "Script": "$target = {{path}}; New-Item -ItemType Directory -Path $target -Force | Out-Null; Resolve-Path $target | Select-Object -ExpandProperty Path"
          }
        }
      },

      "delete_directory": {
        "Description": "Delete an existing subdirectory recursively inside the default writable workspace and return its resolved path.",
        "Shell": "sh",
        "Script": "test -d {{path}} && rm -rf -- {{path}} && printf '%s\n' {{path}}",
        "Parameters": {
          "path": {
            "Description": "Relative directory path to delete recursively inside the writable workspace.",
            "Required": true,
            "Pattern": "^(?![\\\\/])(?!\\.{1,2}$)(?!.*(?:^|[\\\\/])\\.{1,2}(?:[\\\\/]|$))[A-Za-z0-9_.\\\\/-]{1,240}$",
            "MaxLength": 240,
            "IsWorkspacePath": true,
            "MustExist": true,
            "PathKind": "Directory"
          }
        },
        "OsOverrides": {
          "windows": {
            "Shell": "powershell",
            "Script": "$target = {{path}}; if (-not (Test-Path -LiteralPath $target -PathType Container)) { throw \"Directory not found: $target\" }; Remove-Item -LiteralPath $target -Recurse -Force; Write-Output $target"
          }
        }
      },

      "write_markdown_file": {
        "Description": "Create or overwrite a Markdown file inside the default writable workspace. The content must be provided as UTF-8 base64.",
        "Shell": "sh",
        "Script": "mkdir -p \"$(dirname {{path}})\" && printf '%s' {{contentBase64}} | base64 -d > {{path}} && echo {{path}}",
        "Parameters": {
          "path": {
            "Description": "Relative .md file path to create inside the writable workspace.",
            "Required": true,
            "Pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_./\\-]{1,240}\\.md$",
            "MaxLength": 240
          },
          "contentBase64": {
            "Description": "Markdown content encoded as UTF-8 base64.",
            "Required": true,
            "Pattern": "^[A-Za-z0-9+/=\\r\\n]{1,16000}$",
            "MaxLength": 16000
          }
        },
        "OsOverrides": {
          "macos": {
            "Script": "mkdir -p \"$(dirname {{path}})\" && printf '%s' {{contentBase64}} | base64 -D > {{path}} && echo {{path}}"
          },
          "windows": {
            "Shell": "powershell",
            "Script": "$target = {{path}}; $parent = Split-Path -Parent $target; if ($parent) { New-Item -ItemType Directory -Path $parent -Force | Out-Null }; $content = [System.Text.Encoding]::UTF8.GetString([System.Convert]::FromBase64String({{contentBase64}})); [System.IO.File]::WriteAllText($target, $content, [System.Text.UTF8Encoding]::new($false)); Write-Output $target"
          }
        }
      },

      "os_info": {
        "Description": "Display OS and architecture information.",
        "Shell": "sh",
        "Script": "uname -a",
        "OsOverrides": {
          "windows": {
            "Shell": "powershell",
            "Script": "[System.Environment]::OSVersion | ConvertTo-Json"
          }
        }
      },

      "which": {
        "Description": "Locate an executable on the PATH.",
        "Shell": "sh",
        "Script": "which {{name}}",
        "Parameters": {
          "name": {
            "Description": "Name of the executable to locate.",
            "Required": true,
            "Pattern": "^[A-Za-z0-9_.\\-]{1,80}$",
            "MaxLength": 80
          }
        },
        "OsOverrides": {
          "windows": {
            "Shell": "powershell",
            "Script": "Get-Command {{name}} | Select-Object -ExpandProperty Source"
          }
        }
      },

      "cat_file": {
        "Description": "Print the contents of a file inside the default writable workspace.",
        "Shell": "sh",
        "Script": "cat {{path}}",
        "Parameters": {
          "path": {
            "Description": "Relative file path to read inside the writable workspace.",
            "Required": true,
            "Pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_./\\-]{1,240}$",
            "MaxLength": 240
          }
        },
        "OsOverrides": {
          "windows": {
            "Shell": "powershell",
            "Script": "Get-Content -Raw {{path}}"
          }
        }
      },

      "grep_recursive": {
        "Description": "Search for a text pattern recursively in the default writable workspace.",
        "Shell": "sh",
        "Script": "grep -rn --include='{{glob}}' '{{pattern}}' . | head -200",
        "Parameters": {
          "pattern": {
            "Description": "Text or regex pattern to search for.",
            "Required": true,
            "MaxLength": 500
          },
          "glob": {
            "Description": "File glob pattern to filter (e.g. *.cs, *.json).",
            "Required": false,
            "MaxLength": 100
          }
        },
        "OsOverrides": {
          "windows": {
            "Shell": "powershell",
            "Script": "Get-ChildItem -Recurse -Filter '{{glob}}' | Select-String -Pattern '{{pattern}}' | Select-Object -First 200"
          }
        }
      },

      "find_files": {
        "Description": "Find files by name pattern in the default writable workspace.",
        "Shell": "sh",
        "Script": "find . -type f -name '{{pattern}}' | head -200",
        "Parameters": {
          "pattern": {
            "Description": "File name pattern (e.g. *.cs, *.csproj).",
            "Required": true,
            "MaxLength": 200
          }
        },
        "OsOverrides": {
          "windows": {
            "Shell": "powershell",
            "Script": "Get-ChildItem -Recurse -Filter '{{pattern}}' | Select-Object -First 200 -ExpandProperty FullName"
          }
        }
      },

      "dotnet_build": {
        "Description": "Build a .NET project or solution in the default writable workspace.",
        "Shell": "sh",
        "Script": "dotnet build {{path}} --no-restore 2>&1 | tail -100",
        "Parameters": {
          "path": {
            "Description": "Relative path to the .csproj or .sln file to build.",
            "Required": false,
            "Pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_./\\-]{1,240}$",
            "MaxLength": 240
          }
        },
        "OsOverrides": {
          "windows": {
            "Shell": "powershell",
            "Script": "dotnet build {{path}} --no-restore 2>&1 | Select-Object -Last 100"
          }
        }
      },

      "dotnet_restore": {
        "Description": "Restore NuGet packages for a .NET project or solution in the default writable workspace.",
        "Shell": "sh",
        "Script": "dotnet restore {{path}} 2>&1 | tail -50",
        "Parameters": {
          "path": {
            "Description": "Relative path to the .csproj or .sln file to restore.",
            "Required": false,
            "Pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_./\\-]{1,240}$",
            "MaxLength": 240
          }
        },
        "OsOverrides": {
          "windows": {
            "Shell": "powershell",
            "Script": "dotnet restore {{path}} 2>&1 | Select-Object -Last 50"
          }
        }
      },

      "dotnet_test": {
        "Description": "Run tests for a .NET project or solution in the default writable workspace.",
        "Shell": "sh",
        "Script": "dotnet test {{path}} --no-build 2>&1 | tail -100",
        "Parameters": {
          "path": {
            "Description": "Relative path to the test .csproj or .sln file.",
            "Required": false,
            "Pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_./\\-]{1,240}$",
            "MaxLength": 240
          }
        },
        "OsOverrides": {
          "windows": {
            "Shell": "powershell",
            "Script": "dotnet test {{path}} --no-build 2>&1 | Select-Object -Last 100"
          }
        }
      },

      "tree": {
        "Description": "Display the directory tree structure of a relative path in the writable workspace.",
        "Shell": "sh",
        "Script": "find {{path}} -maxdepth {{depth}} | head -300 | sort",
        "Parameters": {
          "path": {
            "Description": "Relative path to inspect.",
            "Required": false,
            "Pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_./\\-]{0,240}$",
            "MaxLength": 240
          },
          "depth": {
            "Description": "Max directory depth (default 3).",
            "Required": false,
            "Pattern": "^[0-9]{1,2}$",
            "MaxLength": 2
          }
        },
        "OsOverrides": {
          "windows": {
            "Shell": "powershell",
            "Script": "Get-ChildItem -Recurse -Depth {{depth}} {{path}} | Select-Object -First 300 -ExpandProperty FullName | Sort-Object"
          }
        }
      },

      "pnpm_install": {
        "Description": "Install Node.js dependencies using pnpm in the default writable workspace.",
        "Shell": "sh",
        "Script": "pnpm install 2>&1 | tail -50"
      },

      "pnpm_run": {
        "Description": "Run a pnpm script in the default writable workspace.",
        "Shell": "sh",
        "Script": "pnpm run {{script}} 2>&1 | tail -100",
        "Parameters": {
          "script": {
            "Description": "Name of the npm script to run.",
            "Required": true,
            "Pattern": "^[A-Za-z0-9_:.-]{1,80}$",
            "MaxLength": 80
          }
        }
      },

      "write_file": {
        "Description": "Create or overwrite any text file inside the default writable workspace. The content must be provided as UTF-8 base64.",
        "Shell": "sh",
        "Script": "mkdir -p \"$(dirname {{path}})\" && printf '%s' {{contentBase64}} | base64 -d > {{path}} && echo {{path}}",
        "Parameters": {
          "path": {
            "Description": "Relative file path to create inside the writable workspace.",
            "Required": true,
            "Pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_./\\-]{1,240}$",
            "MaxLength": 240
          },
          "contentBase64": {
            "Description": "File content encoded as UTF-8 base64.",
            "Required": true,
            "MaxLength": 65536
          }
        },
        "OsOverrides": {
          "macos": {
            "Script": "mkdir -p \"$(dirname {{path}})\" && printf '%s' {{contentBase64}} | base64 -D > {{path}} && echo {{path}}"
          },
          "windows": {
            "Shell": "powershell",
            "Script": "$target = {{path}}; $parent = Split-Path -Parent $target; if ($parent) { New-Item -ItemType Directory -Path $parent -Force | Out-Null }; $content = [System.Text.Encoding]::UTF8.GetString([System.Convert]::FromBase64String({{contentBase64}})); [System.IO.File]::WriteAllText($target, $content, [System.Text.UTF8Encoding]::new($false)); Write-Output $target"
          }
        }
      },

      "delete_file": {
        "Description": "Delete a file inside the default writable workspace.",
        "Shell": "sh",
        "Script": "test -f {{path}} && rm -f -- {{path}} && printf '%s\n' {{path}}",
        "Parameters": {
          "path": {
            "Description": "Relative file path to delete inside the writable workspace.",
            "Required": true,
            "Pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_./\\-]{1,240}$",
            "MaxLength": 240,
            "IsWorkspacePath": true,
            "MustExist": true,
            "PathKind": "File"
          }
        },
        "OsOverrides": {
          "windows": {
            "Shell": "powershell",
            "Script": "$target = {{path}}; if (-not (Test-Path -LiteralPath $target -PathType Leaf)) { throw \"File not found: $target\" }; Remove-Item -LiteralPath $target -Force; Write-Output $target"
          }
        }
      },

      "head_file": {
        "Description": "Print the first N lines of a file in the writable workspace.",
        "Shell": "sh",
        "Script": "head -n {{lines}} {{path}}",
        "Parameters": {
          "path": {
            "Description": "Relative file path to read.",
            "Required": true,
            "Pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_./\\-]{1,240}$",
            "MaxLength": 240
          },
          "lines": {
            "Description": "Number of lines to print (default 50).",
            "Required": false,
            "Pattern": "^[0-9]{1,5}$",
            "MaxLength": 5
          }
        },
        "OsOverrides": {
          "windows": {
            "Shell": "powershell",
            "Script": "Get-Content {{path}} -TotalCount {{lines}}"
          }
        }
      },

      "tail_file": {
        "Description": "Print the last N lines of a file in the writable workspace.",
        "Shell": "sh",
        "Script": "tail -n {{lines}} {{path}}",
        "Parameters": {
          "path": {
            "Description": "Relative file path to read.",
            "Required": true,
            "Pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_./\\-]{1,240}$",
            "MaxLength": 240
          },
          "lines": {
            "Description": "Number of lines to print (default 50).",
            "Required": false,
            "Pattern": "^[0-9]{1,5}$",
            "MaxLength": 5
          }
        },
        "OsOverrides": {
          "windows": {
            "Shell": "powershell",
            "Script": "Get-Content {{path}} -Tail {{lines}}"
          }
        }
      },

      "wc": {
        "Description": "Count lines, words, and characters of a file in the writable workspace.",
        "Shell": "sh",
        "Script": "wc {{path}}",
        "Parameters": {
          "path": {
            "Description": "Relative file path.",
            "Required": true,
            "Pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_./\\-]{1,240}$",
            "MaxLength": 240
          }
        }
      },

      "env": {
        "Description": "Print the current environment variables (filtered to the allow list).",
        "Shell": "sh",
        "Script": "env | sort"
      },

      "rm": {
        "Description": "Remove a file or directory recursively inside the default writable workspace.",
        "Shell": "sh",
        "Script": "rm -rf -- {{path}} && printf 'removed: %s\n' {{path}}",
        "Parameters": {
          "path": {
            "Description": "Relative path to remove inside the writable workspace.",
            "Required": true,
            "Pattern": "^(?![\\\\/])(?!\\.{1,2}$)(?!.*(?:^|[\\\\/])\\.{1,2}(?:[\\\\/]|$))[A-Za-z0-9_.\\\\/-]{1,240}$",
            "MaxLength": 240,
            "IsWorkspacePath": true,
            "MustExist": true
          }
        },
        "OsOverrides": {
          "windows": {
            "Shell": "powershell",
            "Script": "$target = {{path}}; if (Test-Path -LiteralPath $target) { Remove-Item -LiteralPath $target -Recurse -Force }; Write-Output \"removed: $target\""
          }
        }
      }
    }
  },
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "GnOuGo.Cmd.Mcp",
    "OtlpEndpoint": "http://127.0.0.1:4317",
    "Protocol": "Grpc",
    "IncludeLogs": true,
    "IncludeMetrics": true,
    "IncludeHttpClientInstrumentation": true,
    "IncludeAspNetCoreTraces": false
  }
}


