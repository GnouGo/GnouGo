<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- Desktop app packaging -->
    <PublishTrimmed>true</PublishTrimmed>
    <InvariantGlobalization>true</InvariantGlobalization>
    <!-- Required for Blazor interactive endpoints during NativeAOT -->
    <JsonSerializerIsReflectionEnabledByDefault>true</JsonSerializerIsReflectionEnabledByDefault>
    <TrimMode>partial</TrimMode>
    <!-- NativeAOT is enabled at publish time via -p:PublishAot=true -->
    <AssemblyName>GnOuGo.Agent</AssemblyName>
  <Product>GnOuGo.Agent</Product>
  <PackageId>GnOuGo.Agent</PackageId>
  <ApplicationTitle>GnOuGo.Agent</ApplicationTitle>
  <ApplicationIcon>Assets/icon.ico</ApplicationIcon>
</PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Photino.NET" Version="4.0.16" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\GnOuGo.Agent.Server\GnOuGo.Agent.Server.csproj" />
  </ItemGroup>

  <ItemGroup>
    <DesktopBundledTool Include="..\GnOuGo.Browser.Mcp\GnOuGo.Browser.Mcp.csproj">
      <ToolName>GnOuGo.Browser.Mcp</ToolName>
    </DesktopBundledTool>
    <DesktopBundledTool Include="..\GnOuGo.Cmd.Mcp\GnOuGo.Cmd.Mcp.csproj">
      <ToolName>GnOuGo.Cmd.Mcp</ToolName>
    </DesktopBundledTool>
  </ItemGroup>

  <!-- Ensure the web UI static assets and the Agent.Server appsettings (including mounted MCP endpoint placeholders) are present next to the desktop binary -->
    <ItemGroup>
    <Content Include="..\GnOuGo.Agent.Server\appsettings*.json">
      <Link>%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </Content>

    <Content Include="..\GnOuGo.Agent.Server\wwwroot\**\*">
      <Link>wwwroot\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </Content>
  </ItemGroup>

  <!-- Build Vite assets when publishing the desktop app -->
  <Target Name="ViteBuildForDesktop" BeforeTargets="PrepareForPublish" Condition="'$(SkipClientBuild)' != 'true'">
    <Message Importance="high" Text="Building Vite UI assets for desktop publish..." />
    <Exec WorkingDirectory="..\GnOuGo.Agent.Server\ClientApp" Command="npm install" />
    <Exec WorkingDirectory="..\GnOuGo.Agent.Server\ClientApp" Command="npm run build" />
  </Target>

  <!--
    Blazor's unified script (/_framework/blazor.web.js) is resolved via Static Web Assets.
    When the Server is hosted from the Desktop entry assembly, we must copy the Server
    static web assets manifest(s) next to the Desktop executable so UseStaticWebAssets() can load them.
    The manifests may live under bin/<Config>/<TFM>/ or bin/<Config>/<TFM>/<RID>/,
    depending on how MSBuild resolves the Server project.
  -->
  <Target Name="CopyServerStaticWebAssetsManifests" AfterTargets="Build">
    <ItemGroup>
      <_ServerStaticWebAssets Include="..\GnOuGo.Agent.Server\bin\$(Configuration)\$(TargetFramework)\*.staticwebassets.*.json" />
      <_ServerStaticWebAssets Include="..\GnOuGo.Agent.Server\bin\$(Configuration)\$(TargetFramework)\$(RuntimeIdentifier)\*.staticwebassets.*.json" Condition="'$(RuntimeIdentifier)' != ''" />
    </ItemGroup>
    <Message Importance="high" Text="CopyServerStaticWebAssetsManifests: found @(_ServerStaticWebAssets->Count()) manifest(s)" />
    <Copy SourceFiles="@(_ServerStaticWebAssets)" DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" Condition="'@(_ServerStaticWebAssets)' != ''" />
  </Target>

  <Target Name="CopyServerStaticWebAssetsManifestsToPublish" AfterTargets="Publish">
    <ItemGroup>
      <_ServerStaticWebAssetsPublish Include="..\GnOuGo.Agent.Server\bin\$(Configuration)\$(TargetFramework)\*.staticwebassets.*.json" />
      <_ServerStaticWebAssetsPublish Include="..\GnOuGo.Agent.Server\bin\$(Configuration)\$(TargetFramework)\$(RuntimeIdentifier)\*.staticwebassets.*.json" Condition="'$(RuntimeIdentifier)' != ''" />
    </ItemGroup>
    <Message Importance="high" Text="CopyServerStaticWebAssetsManifestsToPublish: found @(_ServerStaticWebAssetsPublish->Count()) manifest(s) -> $(PublishDir)" />
    <Copy SourceFiles="@(_ServerStaticWebAssetsPublish)" DestinationFolder="$(PublishDir)" SkipUnchangedFiles="true" Condition="'@(_ServerStaticWebAssetsPublish)' != ''" />
  </Target>

  <Target Name="PublishBundledDesktopTools" AfterTargets="Publish" Condition="'$(PublishDir)' != '' and '$(RuntimeIdentifier)' != ''">
    <PropertyGroup>
      <BundledToolExecutableExtension Condition="$([MSBuild]::IsOSPlatform('Windows'))">.exe</BundledToolExecutableExtension>
      <BundledToolsRoot>$([System.IO.Path]::GetFullPath('$(PublishDir)tools'))</BundledToolsRoot>
      <BundledBrowserToolDir>$([System.IO.Path]::Combine('$(BundledToolsRoot)', 'GnOuGo.Browser.Mcp'))</BundledBrowserToolDir>
      <BundledCmdToolDir>$([System.IO.Path]::Combine('$(BundledToolsRoot)', 'GnOuGo.Cmd.Mcp'))</BundledCmdToolDir>
      <BundledBrowserToolProject>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\GnOuGo.Browser.Mcp\GnOuGo.Browser.Mcp.csproj'))</BundledBrowserToolProject>
      <BundledCmdToolProject>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\GnOuGo.Cmd.Mcp\GnOuGo.Cmd.Mcp.csproj'))</BundledCmdToolProject>
      <BundledBrowserToolExecutable>$([System.IO.Path]::Combine('$(BundledBrowserToolDir)', 'GnOuGo.Browser.Mcp$(BundledToolExecutableExtension)'))</BundledBrowserToolExecutable>
      <BundledCmdToolExecutable>$([System.IO.Path]::Combine('$(BundledCmdToolDir)', 'GnOuGo.Cmd.Mcp$(BundledToolExecutableExtension)'))</BundledCmdToolExecutable>
    </PropertyGroup>

    <Message Importance="high" Text="Publishing bundled desktop MCP tools into $(BundledToolsRoot) for $(RuntimeIdentifier)..." />

    <Exec Command="dotnet publish &quot;$(BundledBrowserToolProject)&quot; -c $(Configuration) -r $(RuntimeIdentifier) --self-contained true -o &quot;$(BundledBrowserToolDir)&quot; -p:PublishTrimmed=true -p:PublishAot=false" />
    <Exec Command="dotnet publish &quot;$(BundledCmdToolProject)&quot; -c $(Configuration) -r $(RuntimeIdentifier) --self-contained true -o &quot;$(BundledCmdToolDir)&quot; -p:PublishTrimmed=true -p:PublishAot=false" />

    <Error Condition="!Exists('$(BundledBrowserToolExecutable)')" Text="Bundled desktop publish is missing GnOuGo.Browser.Mcp in $(BundledBrowserToolDir)." />
    <Error Condition="!Exists('$(BundledCmdToolExecutable)')" Text="Bundled desktop publish is missing GnOuGo.Cmd.Mcp in $(BundledCmdToolDir)." />
  </Target>


  <ItemGroup>
    <Content Include="Assets/**" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
