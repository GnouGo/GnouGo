{
  "Document": {
    "DefaultWorkingDirectory": "GnOuGo",
    "MaxFileSizeBytes": 52428800,
    "AllowedExtensions": [
      ".pdf",
      ".docx",
      ".xlsx",
      ".pptx",
      ".txt",
      ".md",
      ".csv",
      ".json",
      ".xml",
      ".yaml",
      ".yml"
    ],
    "AllowedWorkingRoots": []
  },
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "GnOuGo.Document.Mcp",
    "OtlpEndpoint": "http://127.0.0.1:4317",
    "Protocol": "Grpc",
    "IncludeLogs": true,
    "IncludeMetrics": true,
    "IncludeHttpClientInstrumentation": true,
    "IncludeAspNetCoreTraces": false
  }
}

