{
  "Code": {
    "DefaultWorkingDirectory": "GnOuGo",
    "MaxFileSizeBytes": 10485760,
    "MaxSearchResults": 500,
    "MaxPromptCharacters": 1256000,
    "AllowWrites": true,
    "AllowedWorkingRoots": [],
    "AllowedExtensions": [
      ".cs",
      ".csproj",
      ".sln",
      ".json",
      ".xml",
      ".yaml",
      ".yml",
      ".md",
      ".txt",
      ".ps1",
      ".sh",
      ".js",
      ".jsx",
      ".ts",
      ".tsx",
      ".py",
      ".css",
      ".html",
      ".razor",
      ".cshtml",
      ".editorconfig",
      ".gitignore",
      ".dockerignore",
      ".dockerfile",
      ".env",
      ".config",
      ".props",
      ".targets",
      ".nuspec",
      ".toml",
      ".ini",
      ".cfg",
      ".sql",
      ".graphql",
      ".proto",
      ".rs",
      ".go",
      ".java",
      ".kt",
      ".swift",
      ".rb",
      ".lua",
      ".r",
      ".scss",
      ".less",
      ".svg",
      ".vue",
      ".svelte",
      ".astro"
    ],
    "Copilot": {
      "Provider": "Copilot",
      "Model": "gpt-5.4-mini",
      "Mode": "ask",
      "ReasoningEffort": "high",
      "Endpoint": "https://models.github.ai/inference",
      "ApiKey": null,
      "UseLoggedInUser": true,
      "ForwardTraceContext": true,
      "LogLevel": "warning",
      "RequestTimeoutSeconds": 7200,
      "Telemetry": {
        "Enabled": true,
        "ExporterType": "otlp",
        "OtlpEndpoint": "http://127.0.0.1:4317",
        "FilePath": null,
        "SourceName": "GnOuGo.GithubCopilot.Mcp.Copilot",
        "CaptureContent": false
      },
      "TokenEnvironmentVariables": [
        "GITHUB_TOKEN",
        "COPILOT_API_KEY"
      ],
      "Providers": {}
    }
  },
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "GnOuGo.GithubCopilot.Mcp",
    "OtlpEndpoint": "http://127.0.0.1:4317",
    "Protocol": "Grpc",
    "IncludeLogs": true,
    "IncludeMetrics": true,
    "IncludeHttpClientInstrumentation": true,
    "IncludeAspNetCoreTraces": false,
    "ActivitySources": [
      "GnOuGo.GithubCopilot.Mcp.Copilot"
    ]
  }
}



