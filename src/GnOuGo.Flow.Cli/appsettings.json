{
  "LLM": {
    "DefaultProvider": "OpenAi",
    "DefaultModel": "gpt-4o-mini",
    "Models": {
      "OpenAi": {
        "Url": "https://api.openai.com/v1",
        "ApiKey": null
      },
      "Ollama": {
        "Url": "http://localhost:11434",
        "Type": "ollama"
      },
      "Copilot": {
        "Url": "https://models.github.ai/inference",
        "Type": "copilot",
        "ApiKey": null
      }
    },
    "McpServers": {
      "Github": {
        "Type": "http",
        "Description": "GitHub repository automation, file access, and developer workflows",
        "Url": "https://api.githubcopilot.com/mcp/",
        "ApiKey": null
      },
      "GnOuGo.Flow.Browser": {
        "Type": "stdio",
        "Description": "Web navigation via Playwright.NET MCP server",
        "Command": "dotnet",
        "Args": [
          "run",
          "--project",
          "src/GnOuGo.Flow.Browser/GnOuGo.Flow.Browser.csproj"
        ]
      },
      "GnOuGo.Flow.Cmd": {
        "Type": "stdio",
        "Description": "Secure allowlisted command execution via stdio MCP server",
        "Command": "dotnet",
        "Args": [
          "run",
          "--project",
          "src/GnOuGo.Flow.Cmd/GnOuGo.Flow.Cmd.csproj"
        ]
      },
      "GnOuGo.Flow.UserData": {
        "Type": "stdio",
        "Description": "User chat history store (append/get conversations) via MCP",
        "Command": "dotnet",
        "Args": [
          "run",
          "--project",
          "src/GnOuGo.Flow.UserData/GnOuGo.Flow.UserData.csproj"
        ]
      }
    }
  }
}
