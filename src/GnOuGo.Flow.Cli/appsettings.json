{
  "LLM": {
    "DefaultProvider": "OpenAi",
    "DefaultModel": "gpt-4o-mini",
    "Models": {
      "OpenAi": {
        "Url": "https://api.openai.com/v1",
        "ApiKey": null
      },
      "Ollama": {
        "Url": "http://localhost:11434",
        "Type": "ollama"
      },
      "Copilot": {
        "Url": "https://models.github.ai/inference",
        "Type": "copilot",
        "ApiKey": null
      }
    },
    "McpServers": {
      "Github": {
        "Type": "http",
        "Description": "GitHub repository automation, file access, and developer workflows",
        "Url": "https://api.githubcopilot.com/mcp/",
        "ApiKey": null
      },
      "GnOuGo.Browser.Mcp": {
        "Type": "stdio",
        "Description": "Web navigation via Playwright.NET MCP server",
        "Command": "dotnet",
        "Args": [
          "run",
          "--project",
          "src/GnOuGo.Browser.Mcp/GnOuGo.Browser.Mcp.csproj"
        ]
      },
      "GnOuGo.Cmd.Mcp": {
        "Type": "stdio",
        "Description": "Secure allowlisted command execution via stdio MCP server",
        "Command": "dotnet",
        "Args": [
          "run",
          "--project",
          "src/GnOuGo.Cmd.Mcp/GnOuGo.Cmd.Mcp.csproj"
        ]
      },
      "GnOuGo.Agent.Mcp": {
        "Type": "http",
        "Description": "Agent management and chat history exposed by the standalone Agent MCP HTTP host",
        "Url": "http://127.0.0.1:5198/mcp"
      }
    }
  }
}
