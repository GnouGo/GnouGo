{
  "Git": {
    "DefaultWorkingDirectory": "GnOuGo",
    "AllowedWorkingRoots": [],
    "AllowMutations": true,
    "AllowNetworkOperations": true,
    "RequireCleanWorkingTreeForMerge": true,
    "MaxDiffCharacters": 500000,
    "MaxLogCount": 500,
    "DefaultAuthorName": "GnOuGo Agent",
    "DefaultAuthorEmail": "gnougo-agent@localhost",
    "DefaultRemoteName": "origin",
    "Username": "x-access-token",
    "Token": null,
    "TokenEnvironmentVariables": [
      "GITHUB_TOKEN",
      "COPILOT_API_KEY"
    ]
  },
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "GnOuGo.Git.Mcp",
    "OtlpEndpoint": "http://127.0.0.1:4317",
    "Protocol": "Grpc",
    "IncludeLogs": true,
    "IncludeMetrics": true,
    "IncludeHttpClientInstrumentation": false,
    "IncludeAspNetCoreTraces": false
  }
}

